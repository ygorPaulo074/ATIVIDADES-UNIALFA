<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://sapien.academic/bpmn" exporter="Camunda Modeler" exporterVersion="5.47.0">
  <collaboration id="Collaboration_cobrancas">
    <participant id="Participant_cobrancas" name="PÁGINA DE COBRANÇAS - SAPIEN" processRef="proc_cobrancas" />
  </collaboration>
  <process id="proc_cobrancas" name="RF07 - Cobrancas" isExecutable="false">
    <laneSet id="ls1">
      <lane id="lane_frontend" name="Frontend">
        <flowNodeRef>task_renderiza</flowNodeRef>
        <flowNodeRef>task_envia_req_cobrancas</flowNodeRef>
        <flowNodeRef>task_envia_req_pagamento</flowNodeRef>
        <flowNodeRef>task_exibe_lista</flowNodeRef>
        <flowNodeRef>end_sem_cobrancas</flowNodeRef>
        <flowNodeRef>task_exibe_sem_cobrancas</flowNodeRef>
        <flowNodeRef>task_recebe_resp_pix</flowNodeRef>
        <flowNodeRef>gw_pix_ok</flowNodeRef>
        <flowNodeRef>task_exibe_pix</flowNodeRef>
        <flowNodeRef>task_exibe_erro_pix</flowNodeRef>
        <flowNodeRef>end_pix_erro</flowNodeRef>
        <flowNodeRef>end_pix_sucesso</flowNodeRef>
        <flowNodeRef>end_boleto_erro</flowNodeRef>
        <flowNodeRef>end_boleto_sucesso</flowNodeRef>
        <flowNodeRef>task_exibe_erro_boleto</flowNodeRef>
        <flowNodeRef>task_exibe_boleto</flowNodeRef>
        <flowNodeRef>gw_boleto_ok</flowNodeRef>
        <flowNodeRef>task_recebe_resp_boleto</flowNodeRef>
        <flowNodeRef>gw_forma_pagamento</flowNodeRef>
      </lane>
      <lane id="lane_usuario" name="Usuario">
        <flowNodeRef>start_cobrancas</flowNodeRef>
        <flowNodeRef>task_seleciona_debito</flowNodeRef>
        <flowNodeRef>task_escolhe_forma</flowNodeRef>
      </lane>
      <lane id="lane_backend" name="Backend / API">
        <flowNodeRef>task_recebe_req_cobrancas</flowNodeRef>
        <flowNodeRef>task_busca_cobrancas</flowNodeRef>
        <flowNodeRef>gw_tem_cobrancas</flowNodeRef>
        <flowNodeRef>task_retorna_cobrancas</flowNodeRef>
        <flowNodeRef>task_ret_sem_cobrancas</flowNodeRef>
        <flowNodeRef>task_recebe_req_pagamento</flowNodeRef>
        <flowNodeRef>gw_tipo_pagamento</flowNodeRef>
        <flowNodeRef>task_gera_pix</flowNodeRef>
        <flowNodeRef>task_gera_boleto</flowNodeRef>
        <flowNodeRef>gw_boleto_gerado</flowNodeRef>
        <flowNodeRef>gw_pix_gerado</flowNodeRef>
        <flowNodeRef>task_retorna_pix</flowNodeRef>
        <flowNodeRef>task_retorna_boleto</flowNodeRef>
        <flowNodeRef>task_retorna_erro_pix</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="start_cobrancas" name="Acessa a pagina de Cobrancas">
      <outgoing>f_start_renderiza</outgoing>
    </startEvent>
    <serviceTask id="task_renderiza" name="Renderiza pagina de Cobrancas">
      <incoming>f_start_renderiza</incoming>
      <outgoing>f_renderiza_envia</outgoing>
    </serviceTask>
    <serviceTask id="task_envia_req_cobrancas" name="Envia requisicao de cobrancas do aluno">
      <incoming>f_renderiza_envia</incoming>
      <outgoing>f_envia_backend</outgoing>
    </serviceTask>
    <serviceTask id="task_envia_req_pagamento" name="Envia requisicao de pagamento com forma escolhida">
      <incoming>f_forma_envia</incoming>
      <outgoing>f_pag_backend</outgoing>
    </serviceTask>
    <serviceTask id="task_recebe_req_cobrancas" name="Recebe requisicao de cobrancas">
      <incoming>f_envia_backend</incoming>
      <outgoing>f_req_busca</outgoing>
    </serviceTask>
    <serviceTask id="task_busca_cobrancas" name="Busca cobrancas do aluno no banco">
      <incoming>f_req_busca</incoming>
      <outgoing>f_busca_gw</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_tem_cobrancas" name="Existem cobrancas para o aluno?">
      <incoming>f_busca_gw</incoming>
      <outgoing>f_cob_sim</outgoing>
      <outgoing>f_cob_nao</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_retorna_cobrancas" name="Retorna lista de cobrancas com status atualizado">
      <incoming>f_cob_sim</incoming>
      <outgoing>f_cobrancas_frontend</outgoing>
    </serviceTask>
    <serviceTask id="task_ret_sem_cobrancas" name="Retorna aviso: nenhuma cobranca encontrada">
      <incoming>f_cob_nao</incoming>
      <outgoing>f_sem_cob_frontend</outgoing>
    </serviceTask>
    <serviceTask id="task_exibe_lista" name="Exibe lista de cobrancas com status visual (Pago, Pendente, Vencido)">
      <incoming>f_cobrancas_frontend</incoming>
      <outgoing>f_lista_usuario</outgoing>
    </serviceTask>
    <endEvent id="end_sem_cobrancas" name="Nenhuma cobranca encontrada">
      <incoming>f_sem_cob_end</incoming>
    </endEvent>
    <serviceTask id="task_exibe_sem_cobrancas" name="Exibe aviso: nenhuma cobranca encontrada">
      <incoming>f_sem_cob_frontend</incoming>
      <outgoing>f_sem_cob_end</outgoing>
    </serviceTask>
    <sequenceFlow id="f_start_renderiza" sourceRef="start_cobrancas" targetRef="task_renderiza" />
    <sequenceFlow id="f_renderiza_envia" sourceRef="task_renderiza" targetRef="task_envia_req_cobrancas" />
    <sequenceFlow id="f_envia_backend" sourceRef="task_envia_req_cobrancas" targetRef="task_recebe_req_cobrancas" />
    <sequenceFlow id="f_forma_envia" sourceRef="task_escolhe_forma" targetRef="task_envia_req_pagamento" />
    <sequenceFlow id="f_pag_backend" sourceRef="task_envia_req_pagamento" targetRef="task_recebe_req_pagamento" />
    <sequenceFlow id="f_recebe_gw_boleto" sourceRef="task_recebe_resp_boleto" targetRef="gw_boleto_ok" />
    <sequenceFlow id="f_boleto_err" sourceRef="gw_boleto_ok" targetRef="task_exibe_erro_boleto" />
    <sequenceFlow id="f_boleto_end" sourceRef="task_exibe_boleto" targetRef="end_boleto_sucesso" />
    <sequenceFlow id="f_boleto_err_end" sourceRef="task_exibe_erro_boleto" targetRef="end_boleto_erro" />
    <sequenceFlow id="f_req_busca" sourceRef="task_recebe_req_cobrancas" targetRef="task_busca_cobrancas" />
    <sequenceFlow id="f_busca_gw" sourceRef="task_busca_cobrancas" targetRef="gw_tem_cobrancas" />
    <sequenceFlow id="f_cob_sim" sourceRef="gw_tem_cobrancas" targetRef="task_retorna_cobrancas" />
    <sequenceFlow id="f_cob_nao" sourceRef="gw_tem_cobrancas" targetRef="task_ret_sem_cobrancas" />
    <sequenceFlow id="f_cobrancas_frontend" sourceRef="task_retorna_cobrancas" targetRef="task_exibe_lista" />
    <sequenceFlow id="f_pag_gw_tipo" sourceRef="task_recebe_req_pagamento" targetRef="gw_tipo_pagamento" />
    <sequenceFlow id="f_tipo_boleto" sourceRef="gw_tipo_pagamento" targetRef="task_gera_boleto" />
    <sequenceFlow id="f_tipo_pix" sourceRef="gw_tipo_pagamento" targetRef="task_gera_pix" />
    <sequenceFlow id="f_gera_gw_boleto" sourceRef="task_gera_boleto" targetRef="gw_boleto_gerado" />
    <sequenceFlow id="f_bg_sim" sourceRef="gw_boleto_gerado" targetRef="task_retorna_boleto" />
    <sequenceFlow id="f_pg_nao" sourceRef="gw_pix_gerado" targetRef="task_gera_pix" />
    <sequenceFlow id="f_sem_cob_frontend" sourceRef="task_ret_sem_cobrancas" targetRef="task_exibe_sem_cobrancas" />
    <sequenceFlow id="f_lista_usuario" sourceRef="task_exibe_lista" targetRef="task_seleciona_debito" />
    <sequenceFlow id="f_sem_cob_end" sourceRef="task_exibe_sem_cobrancas" targetRef="end_sem_cobrancas" />
    <sequenceFlow id="f_seleciona_forma" sourceRef="task_seleciona_debito" targetRef="task_escolhe_forma" />
    <userTask id="task_seleciona_debito" name="Seleciona debito para pagar">
      <incoming>f_lista_usuario</incoming>
      <outgoing>f_seleciona_forma</outgoing>
    </userTask>
    <userTask id="task_escolhe_forma" name="Escolhe forma de pagamento (Boleto ou PIX)">
      <incoming>f_seleciona_forma</incoming>
      <outgoing>f_forma_envia</outgoing>
    </userTask>
    <serviceTask id="task_recebe_req_pagamento" name="Recebe requisicao de pagamento">
      <incoming>f_pag_backend</incoming>
      <outgoing>f_pag_gw_tipo</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_15lk3n7" sourceRef="task_gera_pix" targetRef="gw_pix_gerado" />
    <exclusiveGateway id="gw_tipo_pagamento" name="Tipo de pagamento?">
      <incoming>f_pag_gw_tipo</incoming>
      <outgoing>f_tipo_boleto</outgoing>
      <outgoing>f_tipo_pix</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_gera_pix" name="Gera QR Code PIX dinamicamente">
      <incoming>f_tipo_pix</incoming>
      <incoming>f_pg_nao</incoming>
      <outgoing>Flow_15lk3n7</outgoing>
    </serviceTask>
    <serviceTask id="task_gera_boleto" name="Gera boleto atualizado">
      <incoming>f_tipo_boleto</incoming>
      <outgoing>f_gera_gw_boleto</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_boleto_gerado" name="Boleto gerado?">
      <incoming>f_gera_gw_boleto</incoming>
      <outgoing>f_bg_sim</outgoing>
      <outgoing>Flow_1iokf9x</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="gw_pix_gerado" name="PIX gerado?">
      <incoming>Flow_15lk3n7</incoming>
      <outgoing>f_pg_nao</outgoing>
      <outgoing>Flow_0mjq4sq</outgoing>
      <outgoing>Flow_00zn4nd</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_retorna_pix" name="Retorna QR Code PIX para o Frontend">
      <incoming>Flow_00zn4nd</incoming>
      <outgoing>Flow_1gmkpsv</outgoing>
    </serviceTask>
    <serviceTask id="task_retorna_boleto" name="Retorna boleto para o Frontend">
      <incoming>f_bg_sim</incoming>
      <outgoing>Flow_00osrw6</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_1iokf9x" sourceRef="gw_boleto_gerado" targetRef="task_retorna_erro_pix" />
    <sequenceFlow id="Flow_0mjq4sq" sourceRef="gw_pix_gerado" targetRef="task_retorna_erro_pix" />
    <sequenceFlow id="Flow_00zn4nd" sourceRef="gw_pix_gerado" targetRef="task_retorna_pix" />
    <serviceTask id="task_retorna_erro_pix" name="Retorna erro na geracao do pagamento">
      <incoming>Flow_1iokf9x</incoming>
      <incoming>Flow_0mjq4sq</incoming>
      <outgoing>Flow_1yq62ms</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_00osrw6" sourceRef="task_retorna_boleto" targetRef="gw_forma_pagamento" />
    <sequenceFlow id="Flow_1yq62ms" sourceRef="task_retorna_erro_pix" targetRef="gw_forma_pagamento" />
    <sequenceFlow id="Flow_1gmkpsv" sourceRef="task_retorna_pix" targetRef="gw_forma_pagamento" />
    <serviceTask id="task_recebe_resp_pix" name="Recebe resposta de geracao de PIX">
      <incoming>Flow_0b3kmz2</incoming>
      <outgoing>f_recebe_gw_pix</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_pix_ok" name="PIX gerado com sucesso?">
      <incoming>f_recebe_gw_pix</incoming>
      <outgoing>f_pix_ok</outgoing>
      <outgoing>f_pix_err</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_exibe_pix" name="Exibe QR Code PIX para pagamento">
      <incoming>f_pix_ok</incoming>
      <outgoing>f_pix_end</outgoing>
    </serviceTask>
    <serviceTask id="task_exibe_erro_pix" name="Exibe erro na geracao do PIX">
      <incoming>f_pix_err</incoming>
      <outgoing>f_pix_err_end</outgoing>
    </serviceTask>
    <endEvent id="end_pix_erro" name="Erro na geracao do PIX">
      <incoming>f_pix_err_end</incoming>
    </endEvent>
    <endEvent id="end_pix_sucesso" name="PIX gerado com sucesso">
      <incoming>f_pix_end</incoming>
    </endEvent>
    <sequenceFlow id="f_recebe_gw_pix" sourceRef="task_recebe_resp_pix" targetRef="gw_pix_ok" />
    <sequenceFlow id="f_pix_ok" sourceRef="gw_pix_ok" targetRef="task_exibe_pix" />
    <sequenceFlow id="f_pix_err" sourceRef="gw_pix_ok" targetRef="task_exibe_erro_pix" />
    <sequenceFlow id="f_pix_end" sourceRef="task_exibe_pix" targetRef="end_pix_sucesso" />
    <sequenceFlow id="f_pix_err_end" sourceRef="task_exibe_erro_pix" targetRef="end_pix_erro" />
    <endEvent id="end_boleto_erro" name="Erro na geracao do boleto">
      <incoming>f_boleto_err_end</incoming>
    </endEvent>
    <endEvent id="end_boleto_sucesso" name="Boleto gerado com sucesso">
      <incoming>f_boleto_end</incoming>
    </endEvent>
    <serviceTask id="task_exibe_erro_boleto" name="Exibe erro na geracao do boleto">
      <incoming>f_boleto_err</incoming>
      <outgoing>f_boleto_err_end</outgoing>
    </serviceTask>
    <serviceTask id="task_exibe_boleto" name="Exibe boleto para download">
      <incoming>Flow_141fu5y</incoming>
      <outgoing>f_boleto_end</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_boleto_ok" name="Boleto gerado com sucesso?">
      <incoming>f_recebe_gw_boleto</incoming>
      <outgoing>f_boleto_err</outgoing>
      <outgoing>Flow_141fu5y</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Flow_141fu5y" sourceRef="gw_boleto_ok" targetRef="task_exibe_boleto" />
    <serviceTask id="task_recebe_resp_boleto" name="Recebe resposta de geracao de boleto">
      <incoming>Flow_0e0u5zl</incoming>
      <outgoing>f_recebe_gw_boleto</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_0e0u5zl" sourceRef="gw_forma_pagamento" targetRef="task_recebe_resp_boleto" />
    <sequenceFlow id="Flow_0b3kmz2" sourceRef="gw_forma_pagamento" targetRef="task_recebe_resp_pix" />
    <exclusiveGateway id="gw_forma_pagamento" name="Forma de pagamento recebida?">
      <incoming>Flow_00osrw6</incoming>
      <incoming>Flow_1yq62ms</incoming>
      <incoming>Flow_1gmkpsv</incoming>
      <outgoing>Flow_0e0u5zl</outgoing>
      <outgoing>Flow_0b3kmz2</outgoing>
    </exclusiveGateway>
  </process>
