        <di:waypoint x="360" y="420" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_r_envia" bpmnElement="f_estrutura_envia">
        <di:waypoint x="520" y="420" />
        <di:waypoint x="590" y="420" />
      </bpmndi:BPMNEdge>
