        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_b_aluno" bpmnElement="task_busca_dados_aluno">
        <dc:Bounds x="1200" y="840" width="200" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_b_acad" bpmnElement="task_busca_resumo_academico">
        <dc:Bounds x="1200" y="920" width="200" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_b_fin" bpmnElement="task_busca_resumo_financeiro">
        <dc:Bounds x="1200" y="1000" width="200" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_b_notif" bpmnElement="task_busca_notificacoes">
        <dc:Bounds x="1200" y="1080" width="200" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_gw_b_join" bpmnElement="gw_paralelo_backend_join">
        <dc:Bounds x="1496" y="926" width="48" height="48" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1520" y="980" width="80" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
