      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_b_acad" bpmnElement="f_busca_academico">
        <di:waypoint x="1104" y="950" />
        <di:waypoint x="1200" y="950" />
      </bpmndi:BPMNEdge>
