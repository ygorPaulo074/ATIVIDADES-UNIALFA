<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://sapien.academic/bpmn" exporter="Camunda Modeler" exporterVersion="5.47.0">
  <collaboration id="Collaboration_painel">
    <participant id="Participant_painel" name="PAINEL INICIAL - SAPIEN" processRef="proc_painel" />
  </collaboration>
  <process id="proc_painel" name="Painel Inicial" isExecutable="false">
    <laneSet id="ls1">
      <lane id="lane_usuario" name="Usuario">
        <flowNodeRef>start_painel</flowNodeRef>
      </lane>
      <lane id="lane_frontend" name="Frontend">
        <flowNodeRef>task_renderiza_estrutura</flowNodeRef>
        <flowNodeRef>task_envia_req_dados</flowNodeRef>
        <flowNodeRef>task_renderiza_dados_aluno</flowNodeRef>
        <flowNodeRef>task_renderiza_resumo_academico</flowNodeRef>
        <flowNodeRef>task_renderiza_resumo_financeiro</flowNodeRef>
        <flowNodeRef>task_renderiza_notificacoes</flowNodeRef>
        <flowNodeRef>task_renderiza_atalhos</flowNodeRef>
        <flowNodeRef>gw_paralelo_render</flowNodeRef>
        <flowNodeRef>gw_paralelo_join</flowNodeRef>
        <flowNodeRef>task_exibe_painel_completo</flowNodeRef>
        <flowNodeRef>end_painel</flowNodeRef>
      </lane>
      <lane id="lane_backend" name="Backend / API">
        <flowNodeRef>task_recebe_req</flowNodeRef>
        <flowNodeRef>task_valida_token</flowNodeRef>
        <flowNodeRef>gw_paralelo_backend</flowNodeRef>
        <flowNodeRef>task_busca_dados_aluno</flowNodeRef>
        <flowNodeRef>task_busca_resumo_academico</flowNodeRef>
        <flowNodeRef>task_busca_resumo_financeiro</flowNodeRef>
        <flowNodeRef>task_busca_notificacoes</flowNodeRef>
        <flowNodeRef>gw_paralelo_backend_join</flowNodeRef>
        <flowNodeRef>task_retorna_dados</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="start_painel" name="Login realizado com sucesso (RF01)">
      <outgoing>f_start_renderiza</outgoing>
    </startEvent>
    <serviceTask id="task_renderiza_estrutura" name="Renderiza estrutura base do Painel Inicial">
      <incoming>f_start_renderiza</incoming>
      <outgoing>f_estrutura_envia</outgoing>
    </serviceTask>
    <serviceTask id="task_envia_req_dados" name="Envia requisicao consolidada de dados do painel">
      <incoming>f_estrutura_envia</incoming>
      <outgoing>f_envia_backend</outgoing>
    </serviceTask>
    <serviceTask id="task_renderiza_dados_aluno" name="Renderiza bloco: Dados do Aluno (nome, foto, curso, periodo, CRA)">
      <incoming>f_render_aluno</incoming>
      <outgoing>f_aluno_join</outgoing>
    </serviceTask>
    <serviceTask id="task_renderiza_resumo_academico" name="Renderiza bloco: Resumo Academico (disciplinas, avaliacoes, frequencia)">
      <incoming>f_render_academico</incoming>
      <outgoing>f_academico_join</outgoing>
    </serviceTask>
    <serviceTask id="task_renderiza_resumo_financeiro" name="Renderiza bloco: Resumo Financeiro (cobrancas pendentes, status do semestre)">
      <incoming>Flow_0llpdem</incoming>
      <outgoing>f_financeiro_join</outgoing>
    </serviceTask>
    <serviceTask id="task_renderiza_notificacoes" name="Renderiza bloco: Notificacoes e Avisos institucionais">
      <incoming>f_render_notificacoes</incoming>
      <outgoing>f_notificacoes_join</outgoing>
    </serviceTask>
    <serviceTask id="task_renderiza_atalhos" name="Renderiza bloco: Atalhos Rapidos (Matricula, Boletim, Historico, Cobrancas, Cadastro)">
      <incoming>f_render_atalhos</incoming>
      <outgoing>f_atalhos_join</outgoing>
    </serviceTask>
    <serviceTask id="task_recebe_req" name="Recebe requisicao consolidada do painel">
      <incoming>f_envia_backend</incoming>
      <outgoing>f_req_valida</outgoing>
    </serviceTask>
    <serviceTask id="task_valida_token" name="Valida token JWT e identifica perfil do usuario">
      <incoming>f_req_valida</incoming>
      <outgoing>f_valida_paralelo</outgoing>
    </serviceTask>
    <parallelGateway id="gw_paralelo_backend" name="Inicia buscas paralelas no banco">
      <incoming>f_valida_paralelo</incoming>
      <outgoing>f_busca_aluno</outgoing>
      <outgoing>f_busca_academico</outgoing>
      <outgoing>f_busca_financeiro</outgoing>
      <outgoing>f_busca_notificacoes</outgoing>
    </parallelGateway>
    <serviceTask id="task_busca_dados_aluno" name="Busca dados do aluno (nome, foto, curso, periodo, CRA)">
      <incoming>f_busca_aluno</incoming>
      <outgoing>f_aluno_join_b</outgoing>
    </serviceTask>
    <serviceTask id="task_busca_resumo_academico" name="Busca disciplinas matriculadas, proximas avaliacoes e frequencia geral">
      <incoming>f_busca_academico</incoming>
      <outgoing>f_academico_join_b</outgoing>
    </serviceTask>
    <serviceTask id="task_busca_resumo_financeiro" name="Busca cobrancas pendentes e status do semestre">
      <incoming>f_busca_financeiro</incoming>
      <outgoing>f_financeiro_join_b</outgoing>
    </serviceTask>
    <serviceTask id="task_busca_notificacoes" name="Busca avisos institucionais, alertas de matricula e documentos pendentes">
      <incoming>f_busca_notificacoes</incoming>
      <outgoing>f_notificacoes_join_b</outgoing>
    </serviceTask>
    <parallelGateway id="gw_paralelo_backend_join" name="Aguarda conclusao de todas as buscas">
      <incoming>f_aluno_join_b</incoming>
      <incoming>f_academico_join_b</incoming>
      <incoming>f_financeiro_join_b</incoming>
      <incoming>f_notificacoes_join_b</incoming>
      <outgoing>f_join_retorna</outgoing>
    </parallelGateway>
    <serviceTask id="task_retorna_dados" name="Retorna dados consolidados para o Frontend">
      <incoming>f_join_retorna</incoming>
      <outgoing>f_dados_frontend</outgoing>
    </serviceTask>
    <sequenceFlow id="f_start_renderiza" sourceRef="start_painel" targetRef="task_renderiza_estrutura" />
    <sequenceFlow id="f_estrutura_envia" sourceRef="task_renderiza_estrutura" targetRef="task_envia_req_dados" />
    <sequenceFlow id="f_envia_backend" sourceRef="task_envia_req_dados" targetRef="task_recebe_req" />
    <sequenceFlow id="f_req_valida" sourceRef="task_recebe_req" targetRef="task_valida_token" />
    <sequenceFlow id="f_valida_paralelo" sourceRef="task_valida_token" targetRef="gw_paralelo_backend" />
    <sequenceFlow id="f_busca_aluno" sourceRef="gw_paralelo_backend" targetRef="task_busca_dados_aluno" />
    <sequenceFlow id="f_busca_academico" sourceRef="gw_paralelo_backend" targetRef="task_busca_resumo_academico" />
    <sequenceFlow id="f_busca_financeiro" sourceRef="gw_paralelo_backend" targetRef="task_busca_resumo_financeiro" />
    <sequenceFlow id="f_busca_notificacoes" sourceRef="gw_paralelo_backend" targetRef="task_busca_notificacoes" />
    <sequenceFlow id="f_aluno_join_b" sourceRef="task_busca_dados_aluno" targetRef="gw_paralelo_backend_join" />
    <sequenceFlow id="f_academico_join_b" sourceRef="task_busca_resumo_academico" targetRef="gw_paralelo_backend_join" />
    <sequenceFlow id="f_financeiro_join_b" sourceRef="task_busca_resumo_financeiro" targetRef="gw_paralelo_backend_join" />
    <sequenceFlow id="f_notificacoes_join_b" sourceRef="task_busca_notificacoes" targetRef="gw_paralelo_backend_join" />
    <sequenceFlow id="f_join_retorna" sourceRef="gw_paralelo_backend_join" targetRef="task_retorna_dados" />
    <sequenceFlow id="f_dados_frontend" sourceRef="task_retorna_dados" targetRef="gw_paralelo_render" />
    <sequenceFlow id="f_render_aluno" sourceRef="gw_paralelo_render" targetRef="task_renderiza_dados_aluno" />
    <sequenceFlow id="f_render_academico" sourceRef="gw_paralelo_render" targetRef="task_renderiza_resumo_academico" />
    <sequenceFlow id="f_render_notificacoes" sourceRef="gw_paralelo_render" targetRef="task_renderiza_notificacoes" />
    <sequenceFlow id="f_render_atalhos" sourceRef="gw_paralelo_render" targetRef="task_renderiza_atalhos" />
    <sequenceFlow id="f_aluno_join" sourceRef="task_renderiza_dados_aluno" targetRef="gw_paralelo_join" />
    <sequenceFlow id="f_academico_join" sourceRef="task_renderiza_resumo_academico" targetRef="gw_paralelo_join" />
    <sequenceFlow id="f_financeiro_join" sourceRef="task_renderiza_resumo_financeiro" targetRef="gw_paralelo_join" />
    <sequenceFlow id="f_notificacoes_join" sourceRef="task_renderiza_notificacoes" targetRef="gw_paralelo_join" />
    <sequenceFlow id="f_atalhos_join" sourceRef="task_renderiza_atalhos" targetRef="gw_paralelo_join" />
    <sequenceFlow id="f_join_exibe" sourceRef="gw_paralelo_join" targetRef="task_exibe_painel_completo" />
    <sequenceFlow id="f_painel_end" sourceRef="task_exibe_painel_completo" targetRef="end_painel" />
    <sequenceFlow id="Flow_0llpdem" sourceRef="gw_paralelo_render" targetRef="task_renderiza_resumo_financeiro" />
    <parallelGateway id="gw_paralelo_render" name="Inicia renderizacao paralela dos blocos">
      <incoming>f_dados_frontend</incoming>
      <outgoing>f_render_aluno</outgoing>
      <outgoing>f_render_academico</outgoing>
      <outgoing>f_render_notificacoes</outgoing>
      <outgoing>f_render_atalhos</outgoing>
      <outgoing>Flow_0llpdem</outgoing>
    </parallelGateway>
    <parallelGateway id="gw_paralelo_join" name="Aguarda conclusao de todos os blocos">
      <incoming>f_aluno_join</incoming>
      <incoming>f_academico_join</incoming>
      <incoming>f_financeiro_join</incoming>
      <incoming>f_notificacoes_join</incoming>
      <incoming>f_atalhos_join</incoming>
      <outgoing>f_join_exibe</outgoing>
    </parallelGateway>
    <serviceTask id="task_exibe_painel_completo" name="Exibe Painel Inicial completo ao usuario">
      <incoming>f_join_exibe</incoming>
      <outgoing>f_painel_end</outgoing>
    </serviceTask>
    <endEvent id="end_painel" name="Painel Inicial exibido com sucesso">
      <incoming>f_painel_end</incoming>
    </endEvent>
  </process>
  <bpmndi:BPMNDiagram id="diag_painel">
    <bpmndi:BPMNPlane id="plane_painel" bpmnElement="Collaboration_painel">
      <bpmndi:BPMNShape id="Participant_painel_di" bpmnElement="Participant_painel" isHorizontal="true">
