        <bpmndi:BPMNLabel>
          <dc:Bounds x="1899" y="390" width="62" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="e_start_r" bpmnElement="f_start_renderiza">
        <di:waypoint x="275" y="173" />
