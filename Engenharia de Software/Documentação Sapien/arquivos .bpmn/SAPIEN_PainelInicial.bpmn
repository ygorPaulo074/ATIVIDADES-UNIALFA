          <dc:Bounds x="1471" y="460" width="77" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_exibe_painel" bpmnElement="task_exibe_painel_completo">
        <dc:Bounds x="1660" y="420" width="200" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_end" bpmnElement="end_painel">
