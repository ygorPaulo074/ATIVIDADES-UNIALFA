        <di:waypoint x="1120" y="770" />
        <di:waypoint x="1120" y="474" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_r_aluno" bpmnElement="f_render_aluno">
        <di:waypoint x="1120" y="426" />
        <di:waypoint x="1120" y="285" />
        <di:waypoint x="1240" y="285" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_r_acad" bpmnElement="f_render_academico">
        <di:waypoint x="1120" y="426" />
        <di:waypoint x="1120" y="370" />
        <di:waypoint x="1240" y="370" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_r_notif" bpmnElement="f_render_notificacoes">
        <di:waypoint x="1120" y="474" />
        <di:waypoint x="1120" y="530" />
        <di:waypoint x="1240" y="530" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_r_atal" bpmnElement="f_render_atalhos">
        <di:waypoint x="1120" y="474" />
        <di:waypoint x="1120" y="610" />
        <di:waypoint x="1240" y="610" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_aluno_j" bpmnElement="f_aluno_join">
        <di:waypoint x="1440" y="285" />
        <di:waypoint x="1560" y="285" />
        <di:waypoint x="1560" y="426" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_acad_j" bpmnElement="f_academico_join">
        <di:waypoint x="1440" y="370" />
        <di:waypoint x="1560" y="370" />
        <di:waypoint x="1560" y="426" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_fin_j" bpmnElement="f_financeiro_join">
        <di:waypoint x="1440" y="450" />
