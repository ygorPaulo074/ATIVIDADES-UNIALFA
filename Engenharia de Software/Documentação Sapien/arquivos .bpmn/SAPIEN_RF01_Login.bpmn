    <serviceTask id="task_envia_post" name="Envia POST /auth/login">
      <incoming>f_campos_ok</incoming>
      <outgoing>f_post_backend</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_existe" name="Usuario existe no banco?">
      <incoming>Flow_0a2iy6b</incoming>
