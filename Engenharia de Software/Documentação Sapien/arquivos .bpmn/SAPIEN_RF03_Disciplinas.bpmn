          <dc:Bounds x="1183" y="634" width="74" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_envia_req" bpmnElement="task_envia_req">
        <dc:Bounds x="700" y="380" width="150" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_recebe_req" bpmnElement="task_recebe_req">
        <dc:Bounds x="700" y="860" width="150" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_gw_perm" bpmnElement="gw_permissao" isMarkerVisible="true">
        <dc:Bounds x="921" y="866" width="48" height="48" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="915" y="920" width="60" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_ret403" bpmnElement="task_ret403">
        <dc:Bounds x="870" y="740" width="150" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_busca" bpmnElement="task_busca_disciplinas">
        <dc:Bounds x="1080" y="860" width="160" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_exibe_403" bpmnElement="task_exibe_403">
        <dc:Bounds x="960" y="580" width="160" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_gw_dados" bpmnElement="gw_tem_dados" isMarkerVisible="true">
        <dc:Bounds x="1326" y="866" width="48" height="48" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1383.5" y="870" width="85" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_ret_sem_dados" bpmnElement="task_ret_sem_dados">
        <dc:Bounds x="1270" y="980" width="160" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_exibe_sem_dados" bpmnElement="task_exibe_sem_dados">
        <dc:Bounds x="1570" y="580" width="160" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_end_sem_disc" bpmnElement="end_sem_disciplinas">
        <dc:Bounds x="1842" y="592" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1832" y="634" width="56" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_retorna_disc" bpmnElement="task_retorna_disciplinas">
        <dc:Bounds x="1270" y="740" width="160" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_renderiza_lista" bpmnElement="task_renderiza_lista">
        <dc:Bounds x="1270" y="540" width="160" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_distingue" bpmnElement="task_distingue_tipos">
        <dc:Bounds x="1270" y="400" width="160" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_creditos" bpmnElement="task_exibe_creditos">
        <dc:Bounds x="1500" y="400" width="160" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_end_sucesso" bpmnElement="end_sucesso">
        <dc:Bounds x="1742" y="412" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1728" y="454" width="65" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="e_start_r" bpmnElement="f_start_renderiza">
        <di:waypoint x="280" y="198" />
        <di:waypoint x="280" y="400" />
        <di:waypoint x="365" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_r_sel" bpmnElement="f_renderiza_seleciona">
        <di:waypoint x="440" y="370" />
        <di:waypoint x="440" y="180" />
        <di:waypoint x="530" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_sel_envia" bpmnElement="f_seleciona_envia">
        <di:waypoint x="690" y="180" />
        <di:waypoint x="775" y="180" />
        <di:waypoint x="775" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_envia_b" bpmnElement="f_envia_backend">
        <di:waypoint x="775" y="440" />
        <di:waypoint x="775" y="860" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_req_perm" bpmnElement="f_req_permissao">
        <di:waypoint x="850" y="890" />
        <di:waypoint x="921" y="890" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_perm_s" bpmnElement="f_perm_sim">
        <di:waypoint x="969" y="890" />
        <di:waypoint x="1080" y="890" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1000" y="822" width="30" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_perm_n" bpmnElement="f_perm_nao">
        <di:waypoint x="945" y="866" />
        <di:waypoint x="945" y="800" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="951" y="896" width="30" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_403_f" bpmnElement="f_403_frontend">
        <di:waypoint x="945" y="740" />
        <di:waypoint x="945" y="690" />
        <di:waypoint x="1040" y="690" />
        <di:waypoint x="1040" y="640" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_403_end" bpmnElement="f_403_end">
        <di:waypoint x="1120" y="610" />
        <di:waypoint x="1202" y="610" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_busca_gw" bpmnElement="f_busca_gw">
        <di:waypoint x="1240" y="890" />
        <di:waypoint x="1326" y="890" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_dados_s" bpmnElement="f_dados_sim">
