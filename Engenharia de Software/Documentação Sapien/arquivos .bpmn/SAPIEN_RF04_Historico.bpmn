<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://sapien.academic/bpmn" exporter="Camunda Modeler" exporterVersion="5.47.0">
  <collaboration id="Collaboration_historico">
    <participant id="Participant_historico" name="PÁGINA DE HISTÓRICO ACADÊMICO - SAPIEN" processRef="proc_historico" />
  </collaboration>
  <process id="proc_historico" name="RF04 - Historico Academico" isExecutable="false">
    <laneSet id="ls1">
      <lane id="lane_backend" name="Backend / API">
        <flowNodeRef>task_recebe_req_pdf</flowNodeRef>
        <flowNodeRef>task_gera_pdf_assinado</flowNodeRef>
        <flowNodeRef>gw_pdf_gerado</flowNodeRef>
        <flowNodeRef>task_recebe_req</flowNodeRef>
        <flowNodeRef>gw_permissao</flowNodeRef>
        <flowNodeRef>task_ret403</flowNodeRef>
        <flowNodeRef>task_busca_historico</flowNodeRef>
        <flowNodeRef>gw_tem_dados</flowNodeRef>
        <flowNodeRef>task_ret_sem_dados</flowNodeRef>
        <flowNodeRef>task_calcula_cra</flowNodeRef>
        <flowNodeRef>task_retorna_historico</flowNodeRef>
        <flowNodeRef>task_retorna_pdf</flowNodeRef>
      </lane>
      <lane id="lane_frontend" name="Frontend">
        <flowNodeRef>end_pdf_erro</flowNodeRef>
        <flowNodeRef>task_exibe_403</flowNodeRef>
        <flowNodeRef>end_sem_permissao</flowNodeRef>
        <flowNodeRef>end_sem_historico</flowNodeRef>
        <flowNodeRef>task_exibe_sem_dados</flowNodeRef>
        <flowNodeRef>task_envia_req</flowNodeRef>
        <flowNodeRef>task_renderiza</flowNodeRef>
        <flowNodeRef>task_renderiza_historico</flowNodeRef>
        <flowNodeRef>task_exibe_cra</flowNodeRef>
        <flowNodeRef>end_sucesso</flowNodeRef>
        <flowNodeRef>task_envia_req_pdf</flowNodeRef>
        <flowNodeRef>task_retorna_erro_pdf</flowNodeRef>
        <flowNodeRef>task_exibe_erro_pdf</flowNodeRef>
        <flowNodeRef>task_recebe_resp_pdf</flowNodeRef>
        <flowNodeRef>task_exibe_pdf</flowNodeRef>
        <flowNodeRef>end_pdf_sucesso</flowNodeRef>
      </lane>
      <lane id="lane_usuario" name="Usuario">
        <flowNodeRef>task_solicita_pdf</flowNodeRef>
        <flowNodeRef>start_historico</flowNodeRef>
      </lane>
    </laneSet>
    <endEvent id="end_pdf_erro" name="Erro na geracao do PDF">
      <incoming>f_pdf_err_end</incoming>
    </endEvent>
    <serviceTask id="task_recebe_req_pdf" name="Recebe requisicao de PDF oficial">
      <incoming>f_envia_pdf_backend</incoming>
      <outgoing>f_req_gera_pdf</outgoing>
    </serviceTask>
    <serviceTask id="task_gera_pdf_assinado" name="Gera PDF do historico com assinatura digital institucional">
      <incoming>f_req_gera_pdf</incoming>
      <outgoing>f_gera_gw</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_pdf_gerado" name="PDF gerado com sucesso?">
      <incoming>f_gera_gw</incoming>
      <outgoing>f_gerado_sim</outgoing>
      <outgoing>f_gerado_nao</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_recebe_req" name="Recebe requisicao do historico">
      <incoming>f_envia_backend</incoming>
      <outgoing>f_req_permissao</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_permissao" name="Usuario tem permissao?">
      <incoming>f_req_permissao</incoming>
      <outgoing>f_perm_sim</outgoing>
      <outgoing>f_perm_nao</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_ret403" name="Retorna 403: sem permissao">
      <incoming>f_perm_nao</incoming>
      <outgoing>f_403_frontend</outgoing>
    </serviceTask>
    <serviceTask id="task_exibe_403" name="Exibe mensagem: sem permissao de acesso">
      <incoming>f_403_frontend</incoming>
      <outgoing>f_403_end</outgoing>
    </serviceTask>
    <endEvent id="end_sem_permissao" name="Acesso negado">
      <incoming>f_403_end</incoming>
    </endEvent>
    <serviceTask id="task_busca_historico" name="Busca todas as disciplinas cursadas no banco">
      <incoming>f_perm_sim</incoming>
      <incoming>f_sem_dados_frontend</incoming>
      <outgoing>f_busca_gw</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_tem_dados" name="Existem registros no historico?">
      <incoming>f_busca_gw</incoming>
      <outgoing>f_dados_sim</outgoing>
      <outgoing>f_dados_nao</outgoing>
      <outgoing>Flow_0y86vfg</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_ret_sem_dados" name="Retorna aviso: nenhum historico encontrado">
      <incoming>f_dados_nao</incoming>
      <outgoing>f_sem_dados_frontend</outgoing>
    </serviceTask>
    <endEvent id="end_sem_historico" name="Nenhum historico encontrado">
      <incoming>Flow_156kfff</incoming>
    </endEvent>
    <serviceTask id="task_exibe_sem_dados" name="Exibe aviso: nenhum historico encontrado">
      <incoming>Flow_0y86vfg</incoming>
      <outgoing>Flow_156kfff</outgoing>
    </serviceTask>
    <serviceTask id="task_envia_req" name="Envia requisicao com ID do aluno">
      <incoming>f_renderiza_envia</incoming>
      <outgoing>f_envia_backend</outgoing>
    </serviceTask>
    <serviceTask id="task_renderiza" name="Renderiza pagina de Historico Academico">
      <incoming>f_start_renderiza</incoming>
      <outgoing>f_renderiza_envia</outgoing>
    </serviceTask>
    <userTask id="task_solicita_pdf" name="Solicita emissao do historico oficial em PDF">
      <outgoing>f_solicita_envia_pdf</outgoing>
    </userTask>
    <startEvent id="start_historico" name="Acessa a pagina de Historico Academico">
      <outgoing>f_start_renderiza</outgoing>
    </startEvent>
    <serviceTask id="task_calcula_cra" name="Calcula CRA do aluno">
      <incoming>f_dados_sim</incoming>
      <outgoing>f_calcula_retorna</outgoing>
    </serviceTask>
    <serviceTask id="task_retorna_historico" name="Retorna historico e CRA para o Frontend">
      <incoming>f_calcula_retorna</incoming>
      <outgoing>f_dados_frontend</outgoing>
    </serviceTask>
    <serviceTask id="task_renderiza_historico" name="Renderiza historico com disciplinas ordenadas por semestre">
      <incoming>f_dados_frontend</incoming>
      <outgoing>f_historico_cra</outgoing>
    </serviceTask>
    <serviceTask id="task_exibe_cra" name="Exibe CRA calculado">
      <incoming>f_historico_cra</incoming>
      <outgoing>Flow_1wb99e1</outgoing>
    </serviceTask>
    <endEvent id="end_sucesso" name="Historico exibido com sucesso">
      <incoming>Flow_1wb99e1</incoming>
    </endEvent>
    <serviceTask id="task_envia_req_pdf" name="Envia requisicao de geracao de PDF oficial">
      <incoming>f_solicita_envia_pdf</incoming>
      <outgoing>f_envia_pdf_backend</outgoing>
    </serviceTask>
    <serviceTask id="task_retorna_erro_pdf" name="Retorna erro na geracao do PDF">
      <incoming>f_gerado_nao</incoming>
      <outgoing>Flow_1ayvby8</outgoing>
    </serviceTask>
    <serviceTask id="task_exibe_erro_pdf" name="Exibe alerta de erro na geracao do PDF">
      <incoming>Flow_1ayvby8</incoming>
      <outgoing>f_pdf_err_end</outgoing>
    </serviceTask>
    <serviceTask id="task_retorna_pdf" name="Retorna PDF para o Frontend">
      <incoming>f_gerado_sim</incoming>
      <outgoing>Flow_037994z</outgoing>
    </serviceTask>
    <serviceTask id="task_recebe_resp_pdf" name="Recebe resposta de geracao de PDF">
      <incoming>Flow_037994z</incoming>
      <outgoing>Flow_1dmvz1j</outgoing>
    </serviceTask>
    <serviceTask id="task_exibe_pdf" name="Exibe PDF oficial ao usuario">
      <incoming>Flow_1dmvz1j</incoming>
      <outgoing>f_pdf_end</outgoing>
    </serviceTask>
    <endEvent id="end_pdf_sucesso" name="Historico oficial emitido com sucesso">
      <incoming>f_pdf_end</incoming>
    </endEvent>
    <sequenceFlow id="f_pdf_err_end" sourceRef="task_exibe_erro_pdf" targetRef="end_pdf_erro" />
    <sequenceFlow id="f_envia_pdf_backend" sourceRef="task_envia_req_pdf" targetRef="task_recebe_req_pdf" />
    <sequenceFlow id="f_req_gera_pdf" sourceRef="task_recebe_req_pdf" targetRef="task_gera_pdf_assinado" />
    <sequenceFlow id="f_gera_gw" sourceRef="task_gera_pdf_assinado" targetRef="gw_pdf_gerado" />
    <sequenceFlow id="f_gerado_sim" sourceRef="gw_pdf_gerado" targetRef="task_retorna_pdf" />
    <sequenceFlow id="f_gerado_nao" sourceRef="gw_pdf_gerado" targetRef="task_retorna_erro_pdf" />
    <sequenceFlow id="f_envia_backend" sourceRef="task_envia_req" targetRef="task_recebe_req" />
    <sequenceFlow id="f_req_permissao" sourceRef="task_recebe_req" targetRef="gw_permissao" />
    <sequenceFlow id="f_perm_sim" sourceRef="gw_permissao" targetRef="task_busca_historico" />
    <sequenceFlow id="f_perm_nao" sourceRef="gw_permissao" targetRef="task_ret403" />
    <sequenceFlow id="f_403_frontend" sourceRef="task_ret403" targetRef="task_exibe_403" />
    <sequenceFlow id="f_403_end" sourceRef="task_exibe_403" targetRef="end_sem_permissao" />
    <sequenceFlow id="f_sem_dados_frontend" sourceRef="task_ret_sem_dados" targetRef="task_busca_historico" />
    <sequenceFlow id="f_busca_gw" sourceRef="task_busca_historico" targetRef="gw_tem_dados" />
    <sequenceFlow id="f_dados_sim" sourceRef="gw_tem_dados" targetRef="task_calcula_cra" />
    <sequenceFlow id="f_dados_nao" sourceRef="gw_tem_dados" targetRef="task_ret_sem_dados" />
    <sequenceFlow id="Flow_0y86vfg" sourceRef="gw_tem_dados" targetRef="task_exibe_sem_dados" />
    <sequenceFlow id="Flow_156kfff" sourceRef="task_exibe_sem_dados" targetRef="end_sem_historico" />
    <sequenceFlow id="f_renderiza_envia" sourceRef="task_renderiza" targetRef="task_envia_req" />
    <sequenceFlow id="f_start_renderiza" sourceRef="start_historico" targetRef="task_renderiza" />
    <sequenceFlow id="f_solicita_envia_pdf" sourceRef="task_solicita_pdf" targetRef="task_envia_req_pdf" />
    <sequenceFlow id="f_calcula_retorna" sourceRef="task_calcula_cra" targetRef="task_retorna_historico" />
    <sequenceFlow id="f_dados_frontend" sourceRef="task_retorna_historico" targetRef="task_renderiza_historico" />
    <sequenceFlow id="f_historico_cra" sourceRef="task_renderiza_historico" targetRef="task_exibe_cra" />
    <sequenceFlow id="Flow_1wb99e1" sourceRef="task_exibe_cra" targetRef="end_sucesso" />
    <sequenceFlow id="Flow_1ayvby8" sourceRef="task_retorna_erro_pdf" targetRef="task_exibe_erro_pdf" />
    <sequenceFlow id="Flow_037994z" sourceRef="task_retorna_pdf" targetRef="task_recebe_resp_pdf" />
    <sequenceFlow id="Flow_1dmvz1j" sourceRef="task_recebe_resp_pdf" targetRef="task_exibe_pdf" />
    <sequenceFlow id="f_pdf_end" sourceRef="task_exibe_pdf" targetRef="end_pdf_sucesso" />
  </process>
