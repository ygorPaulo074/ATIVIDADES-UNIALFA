<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://sapien.academic/bpmn" exporter="Camunda Modeler" exporterVersion="5.47.0">
  <collaboration id="Collaboration_matricula">
    <participant id="Participant_matricula" name="PÁGINA DE MATRÍCULA - SAPIEN" processRef="proc_matricula" />
  </collaboration>
  <process id="proc_matricula" name="RF06 - Matricula" isExecutable="false">
    <laneSet id="ls1">
      <lane id="lane_usuario" name="Usuario">
        <flowNodeRef>start_matricula</flowNodeRef>
        <flowNodeRef>task_seleciona_disciplinas</flowNodeRef>
        <flowNodeRef>task_aceita_regras</flowNodeRef>
        <flowNodeRef>task_confirma_matricula</flowNodeRef>
      </lane>
      <lane id="lane_frontend" name="Frontend">
        <flowNodeRef>task_renderiza</flowNodeRef>
        <flowNodeRef>task_envia_req_periodo</flowNodeRef>
        <flowNodeRef>Activity_1c4im5d</flowNodeRef>
        <flowNodeRef>task_exibe_disciplinas</flowNodeRef>
        <flowNodeRef>task_envia_selecao</flowNodeRef>
        <flowNodeRef>task_recebe_resp</flowNodeRef>
        <flowNodeRef>gw_resultado</flowNodeRef>
        <flowNodeRef>task_exibe_confirmacao</flowNodeRef>
        <flowNodeRef>end_sucesso</flowNodeRef>
        <flowNodeRef>task_exibe_fora_periodo</flowNodeRef>
        <flowNodeRef>end_fora_periodo</flowNodeRef>
        <flowNodeRef>task_exibe_financeiro</flowNodeRef>
        <flowNodeRef>end_financeiro</flowNodeRef>
        <flowNodeRef>task_exibe_prereq</flowNodeRef>
        <flowNodeRef>end_prereq</flowNodeRef>
        <flowNodeRef>task_exibe_conflito</flowNodeRef>
        <flowNodeRef>end_conflito</flowNodeRef>
        <flowNodeRef>task_exibe_creditos</flowNodeRef>
        <flowNodeRef>end_creditos</flowNodeRef>
      </lane>
      <lane id="lane_backend" name="Backend / API">
        <flowNodeRef>task_ret_fora_periodo</flowNodeRef>
        <flowNodeRef>task_retorna_disciplinas</flowNodeRef>
        <flowNodeRef>task_busca_disciplinas</flowNodeRef>
        <flowNodeRef>gw_periodo</flowNodeRef>
        <flowNodeRef>task_recebe_req_periodo</flowNodeRef>
        <flowNodeRef>task_recebe_selecao</flowNodeRef>
        <flowNodeRef>gw_financeiro</flowNodeRef>
        <flowNodeRef>task_ret_financeiro</flowNodeRef>
        <flowNodeRef>task_ret_prereq</flowNodeRef>
        <flowNodeRef>task_ret_conflito</flowNodeRef>
        <flowNodeRef>gw_prereq</flowNodeRef>
        <flowNodeRef>gw_conflito</flowNodeRef>
        <flowNodeRef>gw_creditos</flowNodeRef>
        <flowNodeRef>task_ret_creditos</flowNodeRef>
        <flowNodeRef>task_efetiva_matricula</flowNodeRef>
        <flowNodeRef>task_envia_email</flowNodeRef>
        <flowNodeRef>task_retorna_confirmacao</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="start_matricula" name="Acessa o modulo de Matricula">
      <outgoing>f_start_renderiza</outgoing>
    </startEvent>
    <serviceTask id="task_renderiza" name="Renderiza pagina de Matricula">
      <incoming>f_start_renderiza</incoming>
      <outgoing>f_renderiza_envia</outgoing>
    </serviceTask>
    <serviceTask id="task_envia_req_periodo" name="Envia requisicao para verificar periodo de matricula">
      <incoming>f_renderiza_envia</incoming>
      <outgoing>f_envia_periodo_backend</outgoing>
    </serviceTask>
    <sequenceFlow id="f_start_renderiza" sourceRef="start_matricula" targetRef="task_renderiza" />
    <sequenceFlow id="f_renderiza_envia" sourceRef="task_renderiza" targetRef="task_envia_req_periodo" />
    <sequenceFlow id="f_envia_periodo_backend" sourceRef="task_envia_req_periodo" targetRef="task_recebe_req_periodo" />
    <sequenceFlow id="f_exibe_disc_usuario" sourceRef="task_exibe_disciplinas" targetRef="task_seleciona_disciplinas" />
    <sequenceFlow id="f_aceita_confirma" sourceRef="task_aceita_regras" targetRef="task_confirma_matricula" />
    <sequenceFlow id="f_confirma_envia" sourceRef="task_confirma_matricula" targetRef="task_envia_selecao" />
    <sequenceFlow id="f_envia_selecao_backend" sourceRef="task_envia_selecao" targetRef="task_recebe_selecao" />
    <serviceTask id="Activity_1c4im5d" name="Exibe notificação de &#34;Fora do Período de Matrícula&#34;">
      <incoming>Flow_0mxgdg4</incoming>
    </serviceTask>
    <sequenceFlow id="Flow_0mxgdg4" sourceRef="task_ret_fora_periodo" targetRef="Activity_1c4im5d" />
    <serviceTask id="task_exibe_disciplinas" name="Exibe disciplinas disponiveis para selecao">
      <incoming>Flow_1y62w99</incoming>
      <outgoing>f_exibe_disc_usuario</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_1y62w99" sourceRef="task_retorna_disciplinas" targetRef="task_exibe_disciplinas" />
    <userTask id="task_seleciona_disciplinas" name="Seleciona disciplinas para o semestre">
      <incoming>f_exibe_disc_usuario</incoming>
      <outgoing>Flow_0ifyor3</outgoing>
    </userTask>
    <userTask id="task_aceita_regras" name="Confirma aceite das regras de matricula">
      <incoming>Flow_0ifyor3</incoming>
      <outgoing>f_aceita_confirma</outgoing>
    </userTask>
    <sequenceFlow id="Flow_0ifyor3" sourceRef="task_seleciona_disciplinas" targetRef="task_aceita_regras" />
    <userTask id="task_confirma_matricula" name="Confirma a matricula">
      <incoming>f_aceita_confirma</incoming>
      <outgoing>f_confirma_envia</outgoing>
    </userTask>
    <serviceTask id="task_envia_selecao" name="Envia selecao de disciplinas para o Backend">
      <incoming>f_confirma_envia</incoming>
      <outgoing>f_envia_selecao_backend</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_0nnndtc" sourceRef="gw_financeiro" targetRef="task_ret_financeiro" />
    <sequenceFlow id="f_selecao_gw_fin" sourceRef="task_recebe_selecao" targetRef="gw_financeiro" />
    <sequenceFlow id="f_fin_ok" sourceRef="gw_financeiro" targetRef="gw_prereq" />
    <sequenceFlow id="f_prereq_ok" sourceRef="gw_prereq" targetRef="gw_conflito" />
    <sequenceFlow id="f_conflito_ok" sourceRef="gw_conflito" targetRef="gw_creditos" />
    <serviceTask id="task_ret_fora_periodo" name="Retorna aviso: fora do periodo de matricula">
      <incoming>Flow_0u36x09</incoming>
      <outgoing>Flow_0mxgdg4</outgoing>
    </serviceTask>
    <serviceTask id="task_retorna_disciplinas" name="Retorna lista de disciplinas para o Frontend">
      <incoming>f_busca_disc</incoming>
      <outgoing>Flow_1y62w99</outgoing>
    </serviceTask>
    <serviceTask id="task_busca_disciplinas" name="Busca disciplinas disponiveis para o semestre">
      <incoming>f_periodo_sim</incoming>
      <outgoing>f_busca_disc</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_periodo" name="Periodo de matricula aberto?">
      <incoming>f_req_gw_periodo</incoming>
      <outgoing>f_periodo_sim</outgoing>
      <outgoing>Flow_0u36x09</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_recebe_req_periodo" name="Recebe requisicao e verifica periodo de matricula">
      <incoming>f_envia_periodo_backend</incoming>
      <outgoing>f_req_gw_periodo</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_0u36x09" sourceRef="gw_periodo" targetRef="task_ret_fora_periodo" />
    <sequenceFlow id="f_busca_disc" sourceRef="task_busca_disciplinas" targetRef="task_retorna_disciplinas" />
    <sequenceFlow id="f_periodo_sim" sourceRef="gw_periodo" targetRef="task_busca_disciplinas" />
    <sequenceFlow id="f_req_gw_periodo" sourceRef="task_recebe_req_periodo" targetRef="gw_periodo" />
    <serviceTask id="task_recebe_selecao" name="Recebe selecao de disciplinas">
      <incoming>f_envia_selecao_backend</incoming>
      <outgoing>f_selecao_gw_fin</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_financeiro" name="Sem pendencia financeira?">
      <incoming>f_selecao_gw_fin</incoming>
      <outgoing>f_fin_ok</outgoing>
      <outgoing>Flow_0nnndtc</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_ret_financeiro" name="Retorna bloqueio: pendencia financeira">
      <incoming>Flow_0nnndtc</incoming>
      <outgoing>Flow_0iyf9ag</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_0ep6heu" sourceRef="gw_creditos" targetRef="task_ret_creditos" />
    <serviceTask id="task_ret_prereq" name="Retorna erro: pre-requisito nao cumprido">
      <incoming>Flow_0q4goww</incoming>
      <outgoing>Flow_0dy5dhx</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_0q4goww" sourceRef="gw_prereq" targetRef="task_ret_prereq" />
    <exclusiveGateway id="gw_prereq" name="Pre-requisitos cumpridos?">
      <incoming>f_fin_ok</incoming>
      <outgoing>f_prereq_ok</outgoing>
      <outgoing>Flow_0q4goww</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="gw_conflito" name="Sem conflito de horario?">
      <incoming>f_prereq_ok</incoming>
      <outgoing>f_conflito_ok</outgoing>
      <outgoing>Flow_1ul4q3k</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Flow_1ul4q3k" sourceRef="gw_conflito" targetRef="task_ret_conflito" />
    <exclusiveGateway id="gw_creditos" name="Limite de creditos respeitado?">
      <incoming>f_conflito_ok</incoming>
      <outgoing>Flow_0ep6heu</outgoing>
      <outgoing>Flow_0kodddd</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_ret_creditos" name="Retorna erro: limite de creditos excedido">
      <incoming>Flow_0ep6heu</incoming>
      <outgoing>Flow_0hnu4im</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_0hnu4im" sourceRef="task_ret_creditos" targetRef="task_recebe_resp" />
    <serviceTask id="task_ret_conflito" name="Retorna erro: conflito de horario">
      <incoming>Flow_1ul4q3k</incoming>
      <outgoing>Flow_1mw55vd</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_1mw55vd" sourceRef="task_ret_conflito" targetRef="task_recebe_resp" />
    <sequenceFlow id="Flow_0dy5dhx" sourceRef="task_ret_prereq" targetRef="task_recebe_resp" />
    <sequenceFlow id="Flow_0iyf9ag" sourceRef="task_ret_financeiro" targetRef="task_recebe_resp" />
    <sequenceFlow id="Flow_0kodddd" sourceRef="gw_creditos" targetRef="task_efetiva_matricula" />
    <serviceTask id="task_efetiva_matricula" name="Efetiva matricula no banco de dados">
      <incoming>Flow_0kodddd</incoming>
      <outgoing>Flow_1r67csq</outgoing>
    </serviceTask>
    <serviceTask id="task_envia_email" name="Envia e-mail de confirmacao ao aluno">
      <incoming>Flow_1r67csq</incoming>
      <outgoing>Flow_1cvv6dx</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_1r67csq" sourceRef="task_efetiva_matricula" targetRef="task_envia_email" />
    <serviceTask id="task_retorna_confirmacao" name="Retorna confirmacao de matricula ao Frontend">
      <incoming>Flow_1cvv6dx</incoming>
      <outgoing>Flow_0px52fq</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_1cvv6dx" sourceRef="task_envia_email" targetRef="task_retorna_confirmacao" />
    <sequenceFlow id="Flow_0px52fq" sourceRef="task_retorna_confirmacao" targetRef="task_recebe_resp" />
    <serviceTask id="task_recebe_resp" name="Recebe resposta da validacao">
      <incoming>Flow_0hnu4im</incoming>
      <incoming>Flow_1mw55vd</incoming>
      <incoming>Flow_0dy5dhx</incoming>
      <incoming>Flow_0iyf9ag</incoming>
      <incoming>Flow_0px52fq</incoming>
      <outgoing>f_recebe_gw</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_resultado" name="Resultado da validacao?">
      <incoming>f_recebe_gw</incoming>
      <outgoing>f_res_sucesso</outgoing>
      <outgoing>f_res_periodo</outgoing>
      <outgoing>f_res_financeiro</outgoing>
      <outgoing>f_res_prereq</outgoing>
      <outgoing>f_res_conflito</outgoing>
      <outgoing>f_res_creditos</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_exibe_confirmacao" name="Exibe confirmacao de matricula realizada">
      <incoming>f_res_sucesso</incoming>
      <outgoing>f_conf_end</outgoing>
    </serviceTask>
    <endEvent id="end_sucesso" name="Matricula realizada com sucesso">
      <incoming>f_conf_end</incoming>
    </endEvent>
    <serviceTask id="task_exibe_fora_periodo" name="Exibe aviso: matricula fora do periodo">
      <incoming>f_res_periodo</incoming>
      <outgoing>f_periodo_end</outgoing>
    </serviceTask>
    <endEvent id="end_fora_periodo" name="Fora do periodo de matricula">
      <incoming>f_periodo_end</incoming>
    </endEvent>
    <serviceTask id="task_exibe_financeiro" name="Exibe bloqueio: pendencia financeira">
      <incoming>f_res_financeiro</incoming>
      <outgoing>f_financeiro_end</outgoing>
    </serviceTask>
    <endEvent id="end_financeiro" name="Bloqueio por pendencia financeira">
      <incoming>f_financeiro_end</incoming>
    </endEvent>
    <serviceTask id="task_exibe_prereq" name="Exibe erro: pre-requisito nao cumprido">
      <incoming>f_res_prereq</incoming>
      <outgoing>f_prereq_end</outgoing>
    </serviceTask>
    <endEvent id="end_prereq" name="Pre-requisito nao cumprido">
      <incoming>f_prereq_end</incoming>
    </endEvent>
    <serviceTask id="task_exibe_conflito" name="Exibe erro: conflito de horario">
      <incoming>f_res_conflito</incoming>
      <outgoing>f_conflito_end</outgoing>
    </serviceTask>
    <endEvent id="end_conflito" name="Conflito de horario">
      <incoming>f_conflito_end</incoming>
    </endEvent>
    <serviceTask id="task_exibe_creditos" name="Exibe erro: limite de creditos excedido">
      <incoming>f_res_creditos</incoming>
      <outgoing>f_creditos_end</outgoing>
    </serviceTask>
    <endEvent id="end_creditos" name="Limite de creditos excedido">
      <incoming>f_creditos_end</incoming>
    </endEvent>
    <sequenceFlow id="f_recebe_gw" sourceRef="task_recebe_resp" targetRef="gw_resultado" />
    <sequenceFlow id="f_res_sucesso" sourceRef="gw_resultado" targetRef="task_exibe_confirmacao" />
    <sequenceFlow id="f_res_periodo" sourceRef="gw_resultado" targetRef="task_exibe_fora_periodo" />
    <sequenceFlow id="f_res_financeiro" sourceRef="gw_resultado" targetRef="task_exibe_financeiro" />
    <sequenceFlow id="f_res_prereq" sourceRef="gw_resultado" targetRef="task_exibe_prereq" />
    <sequenceFlow id="f_res_conflito" sourceRef="gw_resultado" targetRef="task_exibe_conflito" />
    <sequenceFlow id="f_res_creditos" sourceRef="gw_resultado" targetRef="task_exibe_creditos" />
    <sequenceFlow id="f_conf_end" sourceRef="task_exibe_confirmacao" targetRef="end_sucesso" />
    <sequenceFlow id="f_periodo_end" sourceRef="task_exibe_fora_periodo" targetRef="end_fora_periodo" />
    <sequenceFlow id="f_financeiro_end" sourceRef="task_exibe_financeiro" targetRef="end_financeiro" />
    <sequenceFlow id="f_prereq_end" sourceRef="task_exibe_prereq" targetRef="end_prereq" />
    <sequenceFlow id="f_conflito_end" sourceRef="task_exibe_conflito" targetRef="end_conflito" />
    <sequenceFlow id="f_creditos_end" sourceRef="task_exibe_creditos" targetRef="end_creditos" />
  </process>
