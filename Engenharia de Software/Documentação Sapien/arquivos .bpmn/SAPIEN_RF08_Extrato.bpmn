<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://sapien.academic/bpmn" exporter="Camunda Modeler" exporterVersion="5.47.0">
  <collaboration id="Collaboration_extrato">
    <participant id="Participant_extrato" name="PÁGINA DE EXTRATO FINANCEIRO - SAPIEN" processRef="proc_extrato" />
  </collaboration>
  <process id="proc_extrato" name="RF08 - Extrato Financeiro" isExecutable="false">
    <laneSet id="ls1">
      <lane id="lane_backend" name="Backend / API">
        <flowNodeRef>task_retorna_erro_csv</flowNodeRef>
        <flowNodeRef>task_retorna_pdf</flowNodeRef>
        <flowNodeRef>gw_pdf_gerado</flowNodeRef>
        <flowNodeRef>task_retorna_erro_pdf</flowNodeRef>
        <flowNodeRef>task_retorna_csv</flowNodeRef>
        <flowNodeRef>gw_csv_gerado</flowNodeRef>
        <flowNodeRef>task_gera_csv</flowNodeRef>
        <flowNodeRef>task_gera_pdf</flowNodeRef>
        <flowNodeRef>gw_tipo_backend</flowNodeRef>
        <flowNodeRef>task_aplica_filtros_backend</flowNodeRef>
        <flowNodeRef>task_retorna_extrato</flowNodeRef>
        <flowNodeRef>task_ret_sem_dados</flowNodeRef>
        <flowNodeRef>gw_tem_dados</flowNodeRef>
        <flowNodeRef>task_busca_movimentacoes</flowNodeRef>
        <flowNodeRef>task_recebe_req_extrato</flowNodeRef>
        <flowNodeRef>task_recebe_req_exportacao</flowNodeRef>
      </lane>
      <lane id="lane_frontend" name="Frontend">
        <flowNodeRef>task_renderiza</flowNodeRef>
        <flowNodeRef>task_envia_req_extrato</flowNodeRef>
        <flowNodeRef>task_recebe_resp_pdf</flowNodeRef>
        <flowNodeRef>gw_pdf_ok</flowNodeRef>
        <flowNodeRef>task_exibe_pdf</flowNodeRef>
        <flowNodeRef>end_pdf_sucesso</flowNodeRef>
        <flowNodeRef>task_exibe_erro_pdf</flowNodeRef>
        <flowNodeRef>end_pdf_erro</flowNodeRef>
        <flowNodeRef>task_recebe_resp_csv</flowNodeRef>
        <flowNodeRef>gw_csv_ok</flowNodeRef>
        <flowNodeRef>task_exibe_csv</flowNodeRef>
        <flowNodeRef>end_csv_sucesso</flowNodeRef>
        <flowNodeRef>task_exibe_erro_csv</flowNodeRef>
        <flowNodeRef>end_csv_erro</flowNodeRef>
        <flowNodeRef>gw_tipo_exportacao</flowNodeRef>
        <flowNodeRef>task_envia_req_exportacao</flowNodeRef>
        <flowNodeRef>task_exibe_extrato</flowNodeRef>
        <flowNodeRef>task_exibe_sem_dados</flowNodeRef>
        <flowNodeRef>end_sem_dados</flowNodeRef>
      </lane>
      <lane id="lane_usuario" name="Usuario">
        <flowNodeRef>start_extrato</flowNodeRef>
        <flowNodeRef>task_seleciona_periodo</flowNodeRef>
        <flowNodeRef>task_aplica_filtros</flowNodeRef>
        <flowNodeRef>task_solicita_exportacao</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="start_extrato" name="Acessa a pagina de Extrato Financeiro">
      <outgoing>f_start_renderiza</outgoing>
    </startEvent>
    <userTask id="task_seleciona_periodo" name="Seleciona periodo de consulta">
      <incoming>f_renderiza_seleciona</incoming>
      <outgoing>f_seleciona_filtros</outgoing>
    </userTask>
    <userTask id="task_aplica_filtros" name="Aplica filtros opcionais (tipo, status)">
      <incoming>f_seleciona_filtros</incoming>
      <outgoing>f_filtros_envia</outgoing>
    </userTask>
    <serviceTask id="task_renderiza" name="Renderiza pagina de Extrato Financeiro">
      <incoming>f_start_renderiza</incoming>
      <outgoing>f_renderiza_seleciona</outgoing>
    </serviceTask>
    <serviceTask id="task_envia_req_extrato" name="Envia requisicao com periodo e filtros">
      <incoming>f_filtros_envia</incoming>
      <outgoing>f_envia_backend</outgoing>
    </serviceTask>
    <serviceTask id="task_recebe_resp_pdf" name="Recebe resposta de exportacao PDF">
      <incoming>f_res_pdf</incoming>
      <outgoing>f_recebe_gw_pdf</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_pdf_ok" name="PDF gerado com sucesso?">
      <incoming>f_recebe_gw_pdf</incoming>
      <outgoing>f_pdf_ok</outgoing>
      <outgoing>f_pdf_err</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_exibe_pdf" name="Disponibiliza download do PDF">
      <incoming>f_pdf_ok</incoming>
      <outgoing>f_pdf_end</outgoing>
    </serviceTask>
    <endEvent id="end_pdf_sucesso" name="PDF exportado com sucesso">
      <incoming>f_pdf_end</incoming>
    </endEvent>
    <serviceTask id="task_exibe_erro_pdf" name="Exibe erro na exportacao do PDF">
      <incoming>f_pdf_err</incoming>
      <outgoing>f_pdf_err_end</outgoing>
    </serviceTask>
    <endEvent id="end_pdf_erro" name="Erro na exportacao do PDF">
      <incoming>f_pdf_err_end</incoming>
    </endEvent>
    <serviceTask id="task_recebe_resp_csv" name="Recebe resposta de exportacao CSV">
      <incoming>f_res_csv</incoming>
      <outgoing>f_recebe_gw_csv</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_csv_ok" name="CSV gerado com sucesso?">
      <incoming>f_recebe_gw_csv</incoming>
      <outgoing>f_csv_ok</outgoing>
      <outgoing>f_csv_err</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_exibe_csv" name="Disponibiliza download do CSV">
      <incoming>f_csv_ok</incoming>
      <outgoing>f_csv_end</outgoing>
    </serviceTask>
    <endEvent id="end_csv_sucesso" name="CSV exportado com sucesso">
      <incoming>f_csv_end</incoming>
    </endEvent>
    <serviceTask id="task_exibe_erro_csv" name="Exibe erro na exportacao do CSV">
      <incoming>f_csv_err</incoming>
      <outgoing>f_csv_err_end</outgoing>
    </serviceTask>
    <endEvent id="end_csv_erro" name="Erro na exportacao do CSV">
      <incoming>f_csv_err_end</incoming>
    </endEvent>
    <userTask id="task_solicita_exportacao" name="Solicita exportacao (PDF ou CSV)">
      <outgoing>f_exportacao_envia</outgoing>
    </userTask>
    <exclusiveGateway id="gw_tipo_exportacao" name="Tipo de exportacao recebida?">
      <incoming>f_pdf_frontend</incoming>
      <incoming>f_pdf_err_frontend</incoming>
      <incoming>f_csv_frontend</incoming>
      <incoming>f_csv_err_frontend</incoming>
      <outgoing>f_res_pdf</outgoing>
      <outgoing>f_res_csv</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_envia_req_exportacao" name="Envia requisicao de exportacao">
      <incoming>f_exportacao_envia</incoming>
      <outgoing>f_exportacao_backend</outgoing>
    </serviceTask>
    <serviceTask id="task_retorna_erro_csv" name="Retorna erro na geracao do CSV">
      <incoming>f_csv_nao</incoming>
      <outgoing>f_csv_err_frontend</outgoing>
    </serviceTask>
    <serviceTask id="task_retorna_pdf" name="Retorna PDF para o Frontend">
      <incoming>f_pdf_sim</incoming>
      <outgoing>f_pdf_frontend</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_pdf_gerado" name="PDF gerado?">
      <incoming>f_gera_gw_pdf</incoming>
      <outgoing>f_pdf_sim</outgoing>
      <outgoing>f_pdf_nao</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_retorna_erro_pdf" name="Retorna erro na geracao do PDF">
      <incoming>f_pdf_nao</incoming>
      <outgoing>f_pdf_err_frontend</outgoing>
    </serviceTask>
    <serviceTask id="task_retorna_csv" name="Retorna CSV para o Frontend">
      <incoming>f_csv_sim</incoming>
      <outgoing>f_csv_frontend</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_csv_gerado" name="CSV gerado?">
      <incoming>f_gera_gw_csv</incoming>
      <outgoing>f_csv_sim</outgoing>
      <outgoing>f_csv_nao</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_gera_csv" name="Gera arquivo CSV do extrato">
      <incoming>f_tipo_csv</incoming>
      <outgoing>f_gera_gw_csv</outgoing>
    </serviceTask>
    <serviceTask id="task_gera_pdf" name="Gera arquivo PDF do extrato">
      <incoming>f_tipo_pdf</incoming>
      <outgoing>f_gera_gw_pdf</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_tipo_backend" name="Tipo de exportacao?">
      <incoming>f_exp_gw_tipo</incoming>
      <outgoing>f_tipo_pdf</outgoing>
      <outgoing>f_tipo_csv</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_aplica_filtros_backend" name="Aplica filtros e organiza movimentacoes">
      <incoming>f_dados_sim</incoming>
      <outgoing>f_filtros_retorna</outgoing>
    </serviceTask>
    <serviceTask id="task_retorna_extrato" name="Retorna extrato para o Frontend">
      <incoming>f_filtros_retorna</incoming>
      <outgoing>f_extrato_frontend</outgoing>
    </serviceTask>
    <serviceTask id="task_ret_sem_dados" name="Retorna aviso: sem movimentacoes no periodo">
      <incoming>f_dados_nao</incoming>
      <outgoing>f_sem_dados_frontend</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_tem_dados" name="Existem movimentacoes no periodo?">
      <incoming>f_busca_gw</incoming>
      <outgoing>f_dados_sim</outgoing>
      <outgoing>f_dados_nao</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_busca_movimentacoes" name="Busca movimentacoes do periodo no banco">
      <incoming>f_req_busca</incoming>
      <outgoing>f_busca_gw</outgoing>
    </serviceTask>
    <sequenceFlow id="f_start_renderiza" sourceRef="start_extrato" targetRef="task_renderiza" />
    <sequenceFlow id="f_renderiza_seleciona" sourceRef="task_renderiza" targetRef="task_seleciona_periodo" />
    <sequenceFlow id="f_seleciona_filtros" sourceRef="task_seleciona_periodo" targetRef="task_aplica_filtros" />
    <sequenceFlow id="f_filtros_envia" sourceRef="task_aplica_filtros" targetRef="task_envia_req_extrato" />
    <sequenceFlow id="f_envia_backend" sourceRef="task_envia_req_extrato" targetRef="task_recebe_req_extrato" />
    <sequenceFlow id="f_res_pdf" sourceRef="gw_tipo_exportacao" targetRef="task_recebe_resp_pdf" />
    <sequenceFlow id="f_recebe_gw_pdf" sourceRef="task_recebe_resp_pdf" targetRef="gw_pdf_ok" />
    <sequenceFlow id="f_pdf_ok" sourceRef="gw_pdf_ok" targetRef="task_exibe_pdf" />
    <sequenceFlow id="f_pdf_err" sourceRef="gw_pdf_ok" targetRef="task_exibe_erro_pdf" />
    <sequenceFlow id="f_pdf_end" sourceRef="task_exibe_pdf" targetRef="end_pdf_sucesso" />
    <sequenceFlow id="f_pdf_err_end" sourceRef="task_exibe_erro_pdf" targetRef="end_pdf_erro" />
    <sequenceFlow id="f_res_csv" sourceRef="gw_tipo_exportacao" targetRef="task_recebe_resp_csv" />
    <sequenceFlow id="f_recebe_gw_csv" sourceRef="task_recebe_resp_csv" targetRef="gw_csv_ok" />
    <sequenceFlow id="f_csv_ok" sourceRef="gw_csv_ok" targetRef="task_exibe_csv" />
    <sequenceFlow id="f_csv_err" sourceRef="gw_csv_ok" targetRef="task_exibe_erro_csv" />
    <sequenceFlow id="f_csv_end" sourceRef="task_exibe_csv" targetRef="end_csv_sucesso" />
    <sequenceFlow id="f_csv_err_end" sourceRef="task_exibe_erro_csv" targetRef="end_csv_erro" />
    <sequenceFlow id="f_exportacao_envia" sourceRef="task_solicita_exportacao" targetRef="task_envia_req_exportacao" />
    <sequenceFlow id="f_pdf_frontend" sourceRef="task_retorna_pdf" targetRef="gw_tipo_exportacao" />
    <sequenceFlow id="f_pdf_err_frontend" sourceRef="task_retorna_erro_pdf" targetRef="gw_tipo_exportacao" />
    <sequenceFlow id="f_csv_frontend" sourceRef="task_retorna_csv" targetRef="gw_tipo_exportacao" />
    <sequenceFlow id="f_csv_err_frontend" sourceRef="task_retorna_erro_csv" targetRef="gw_tipo_exportacao" />
    <sequenceFlow id="f_exportacao_backend" sourceRef="task_envia_req_exportacao" targetRef="task_recebe_req_exportacao" />
    <sequenceFlow id="f_extrato_frontend" sourceRef="task_retorna_extrato" targetRef="task_exibe_extrato" />
    <sequenceFlow id="f_sem_dados_frontend" sourceRef="task_ret_sem_dados" targetRef="task_exibe_sem_dados" />
    <sequenceFlow id="Flow_1bxuwtp" sourceRef="task_exibe_sem_dados" targetRef="end_sem_dados" />
    <sequenceFlow id="f_csv_nao" sourceRef="gw_csv_gerado" targetRef="task_retorna_erro_csv" />
    <sequenceFlow id="f_pdf_sim" sourceRef="gw_pdf_gerado" targetRef="task_retorna_pdf" />
    <sequenceFlow id="f_gera_gw_pdf" sourceRef="task_gera_pdf" targetRef="gw_pdf_gerado" />
    <sequenceFlow id="f_pdf_nao" sourceRef="gw_pdf_gerado" targetRef="task_retorna_erro_pdf" />
    <sequenceFlow id="f_csv_sim" sourceRef="gw_csv_gerado" targetRef="task_retorna_csv" />
    <sequenceFlow id="f_gera_gw_csv" sourceRef="task_gera_csv" targetRef="gw_csv_gerado" />
    <sequenceFlow id="f_tipo_csv" sourceRef="gw_tipo_backend" targetRef="task_gera_csv" />
    <sequenceFlow id="f_tipo_pdf" sourceRef="gw_tipo_backend" targetRef="task_gera_pdf" />
    <sequenceFlow id="f_exp_gw_tipo" sourceRef="task_recebe_req_exportacao" targetRef="gw_tipo_backend" />
    <sequenceFlow id="f_dados_sim" sourceRef="gw_tem_dados" targetRef="task_aplica_filtros_backend" />
    <sequenceFlow id="f_filtros_retorna" sourceRef="task_aplica_filtros_backend" targetRef="task_retorna_extrato" />
    <sequenceFlow id="f_dados_nao" sourceRef="gw_tem_dados" targetRef="task_ret_sem_dados" />
    <sequenceFlow id="f_busca_gw" sourceRef="task_busca_movimentacoes" targetRef="gw_tem_dados" />
    <sequenceFlow id="f_req_busca" sourceRef="task_recebe_req_extrato" targetRef="task_busca_movimentacoes" />
    <serviceTask id="task_recebe_req_extrato" name="Recebe requisicao do extrato">
      <incoming>f_envia_backend</incoming>
      <outgoing>f_req_busca</outgoing>
    </serviceTask>
    <serviceTask id="task_recebe_req_exportacao" name="Recebe requisicao de exportacao">
      <incoming>f_exportacao_backend</incoming>
      <outgoing>f_exp_gw_tipo</outgoing>
    </serviceTask>
    <serviceTask id="task_exibe_extrato" name="Exibe extrato com movimentacoes do periodo">
      <incoming>f_extrato_frontend</incoming>
    </serviceTask>
    <serviceTask id="task_exibe_sem_dados" name="Exibe aviso: sem movimentacoes no periodo">
      <incoming>f_sem_dados_frontend</incoming>
      <outgoing>Flow_1bxuwtp</outgoing>
    </serviceTask>
    <endEvent id="end_sem_dados" name="Sem movimentacoes no periodo">
      <incoming>Flow_1bxuwtp</incoming>
    </endEvent>
  </process>
