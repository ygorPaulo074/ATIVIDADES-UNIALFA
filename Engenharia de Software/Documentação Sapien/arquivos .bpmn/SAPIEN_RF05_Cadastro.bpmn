<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://sapien.academic/bpmn" exporter="Camunda Modeler" exporterVersion="5.47.0">
  <collaboration id="Collaboration_cadastro">
    <participant id="Participant_cadastro" name="PÁGINA DE DADOS CADASTRAIS - SAPIEN" processRef="proc_cadastro" />
  </collaboration>
  <process id="proc_cadastro" name="RF05 - Dados Cadastrais" isExecutable="false">
    <laneSet id="ls1">
      <lane id="lane_usuario" name="Usuario">
        <flowNodeRef>start_cadastro</flowNodeRef>
        <flowNodeRef>task_edita_campos</flowNodeRef>
        <flowNodeRef>task_visualiza_dados</flowNodeRef>
        <flowNodeRef>task_confirma_alteracoes</flowNodeRef>
      </lane>
      <lane id="lane_frontend" name="Frontend">
        <flowNodeRef>task_renderiza</flowNodeRef>
        <flowNodeRef>task_envia_req_dados</flowNodeRef>
        <flowNodeRef>task_exibe_formulario</flowNodeRef>
        <flowNodeRef>gw_campos_validos</flowNodeRef>
        <flowNodeRef>task_envia_alteracoes</flowNodeRef>
        <flowNodeRef>task_exibe_confirmacao</flowNodeRef>
        <flowNodeRef>task_exibe_erro_salvar</flowNodeRef>
        <flowNodeRef>end_erro_salvar</flowNodeRef>
        <flowNodeRef>end_sucesso</flowNodeRef>
        <flowNodeRef>gw_salvo</flowNodeRef>
        <flowNodeRef>task_recebe_resp_salvar</flowNodeRef>
        <flowNodeRef>task_exibe_erro_validacao</flowNodeRef>
      </lane>
      <lane id="lane_backend" name="Backend / API">
        <flowNodeRef>task_retorna_confirmacao</flowNodeRef>
        <flowNodeRef>task_retorna_erro_salvar</flowNodeRef>
        <flowNodeRef>task_registra_log</flowNodeRef>
        <flowNodeRef>gw_salvo_backend</flowNodeRef>
        <flowNodeRef>task_valida_salva</flowNodeRef>
        <flowNodeRef>task_recebe_alteracoes</flowNodeRef>
        <flowNodeRef>task_retorna_dados</flowNodeRef>
        <flowNodeRef>task_busca_dados</flowNodeRef>
        <flowNodeRef>task_recebe_req_dados</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="start_cadastro" name="Acessa a pagina de Dados Cadastrais">
      <outgoing>f_start_renderiza</outgoing>
    </startEvent>
    <serviceTask id="task_renderiza" name="Renderiza pagina de Dados Cadastrais">
      <incoming>f_start_renderiza</incoming>
      <outgoing>f_renderiza_envia</outgoing>
    </serviceTask>
    <serviceTask id="task_envia_req_dados" name="Envia requisicao de busca dos dados cadastrais">
      <incoming>f_renderiza_envia</incoming>
      <outgoing>f_envia_backend_dados</outgoing>
    </serviceTask>
    <sequenceFlow id="f_start_renderiza" sourceRef="start_cadastro" targetRef="task_renderiza" />
    <sequenceFlow id="f_renderiza_envia" sourceRef="task_renderiza" targetRef="task_envia_req_dados" />
    <sequenceFlow id="f_envia_backend_dados" sourceRef="task_envia_req_dados" targetRef="task_recebe_req_dados" />
    <sequenceFlow id="f_dados_frontend" sourceRef="task_retorna_dados" targetRef="task_exibe_formulario" />
    <sequenceFlow id="f_confirma_envia" sourceRef="task_confirma_alteracoes" targetRef="gw_campos_validos" />
    <sequenceFlow id="f_envia_backend_alt" sourceRef="task_envia_alteracoes" targetRef="task_recebe_alteracoes" />
    <serviceTask id="task_exibe_formulario" name="Exibe dados no formulario">
      <incoming>f_dados_frontend</incoming>
      <outgoing>Flow_0tzh78t</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_campos_validos" name="Campos validos?">
      <incoming>f_confirma_envia</incoming>
      <outgoing>Flow_0ey3pg7</outgoing>
      <outgoing>Flow_0ctbhy2</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Flow_0ey3pg7" sourceRef="gw_campos_validos" targetRef="task_envia_alteracoes" />
    <serviceTask id="task_envia_alteracoes" name="Envia alteracoes para o Backend">
      <incoming>Flow_0ey3pg7</incoming>
      <outgoing>f_envia_backend_alt</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_0ctbhy2" sourceRef="gw_campos_validos" targetRef="task_exibe_erro_validacao" />
    <serviceTask id="task_exibe_confirmacao" name="Exibe mensagem de confirmacao">
      <incoming>f_salvo_ok</incoming>
      <outgoing>f_confirmacao_end</outgoing>
    </serviceTask>
    <serviceTask id="task_exibe_erro_salvar" name="Exibe mensagem de erro ao salvar">
      <incoming>Flow_1r8ngbp</incoming>
      <outgoing>Flow_1v1x8w9</outgoing>
    </serviceTask>
    <endEvent id="end_erro_salvar" name="Erro ao salvar dados">
      <incoming>Flow_1v1x8w9</incoming>
    </endEvent>
    <endEvent id="end_sucesso" name="Dados atualizados com sucesso">
      <incoming>f_confirmacao_end</incoming>
    </endEvent>
    <exclusiveGateway id="gw_salvo" name="Dados salvos com sucesso?">
      <incoming>f_recebe_gw_salvo</incoming>
      <outgoing>f_salvo_ok</outgoing>
      <outgoing>Flow_1r8ngbp</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_recebe_resp_salvar" name="Recebe resposta de salvamento">
      <incoming>Flow_1kaj9ag</incoming>
      <incoming>Flow_0lkr8nf</incoming>
      <outgoing>f_recebe_gw_salvo</outgoing>
    </serviceTask>
    <sequenceFlow id="f_salvo_ok" sourceRef="gw_salvo" targetRef="task_exibe_confirmacao" />
    <sequenceFlow id="f_confirmacao_end" sourceRef="task_exibe_confirmacao" targetRef="end_sucesso" />
    <sequenceFlow id="Flow_1r8ngbp" sourceRef="gw_salvo" targetRef="task_exibe_erro_salvar" />
    <sequenceFlow id="Flow_1v1x8w9" sourceRef="task_exibe_erro_salvar" targetRef="end_erro_salvar" />
    <sequenceFlow id="f_recebe_gw_salvo" sourceRef="task_recebe_resp_salvar" targetRef="gw_salvo" />
    <sequenceFlow id="Flow_1kaj9ag" sourceRef="task_retorna_erro_salvar" targetRef="task_recebe_resp_salvar" />
    <sequenceFlow id="Flow_0lkr8nf" sourceRef="task_retorna_confirmacao" targetRef="task_recebe_resp_salvar" />
    <sequenceFlow id="Flow_0tzh78t" sourceRef="task_exibe_formulario" targetRef="task_visualiza_dados" />
    <userTask id="task_edita_campos" name="Edita campos permitidos (exceto CPF e e-mail institucional)">
      <incoming>Flow_02wwrbg</incoming>
      <incoming>Flow_01nfx0r</incoming>
      <outgoing>Flow_07ui1fh</outgoing>
    </userTask>
    <userTask id="task_visualiza_dados" name="Visualiza seus dados cadastrais">
      <incoming>Flow_0tzh78t</incoming>
      <outgoing>Flow_02wwrbg</outgoing>
    </userTask>
    <userTask id="task_confirma_alteracoes" name="Confirma as alteracoes">
      <incoming>Flow_07ui1fh</incoming>
      <outgoing>f_confirma_envia</outgoing>
    </userTask>
    <sequenceFlow id="Flow_02wwrbg" sourceRef="task_visualiza_dados" targetRef="task_edita_campos" />
    <sequenceFlow id="Flow_07ui1fh" sourceRef="task_edita_campos" targetRef="task_confirma_alteracoes" />
    <serviceTask id="task_retorna_confirmacao" name="Retorna confirmacao de sucesso">
      <incoming>Flow_04a4zxd</incoming>
      <outgoing>Flow_0lkr8nf</outgoing>
    </serviceTask>
    <serviceTask id="task_retorna_erro_salvar" name="Retorna erro ao salvar">
      <incoming>f_backend_err</incoming>
      <outgoing>Flow_1kaj9ag</outgoing>
    </serviceTask>
    <serviceTask id="task_registra_log" name="Registra log (data, hora e IP da alteracao)">
      <incoming>f_backend_ok</incoming>
      <outgoing>Flow_04a4zxd</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_salvo_backend" name="Salvou com sucesso?">
      <incoming>f_salva_gw</incoming>
      <outgoing>f_backend_ok</outgoing>
      <outgoing>f_backend_err</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_valida_salva" name="Valida e salva alteracoes no banco">
      <incoming>f_alt_valida</incoming>
      <outgoing>f_salva_gw</outgoing>
    </serviceTask>
    <serviceTask id="task_recebe_alteracoes" name="Recebe alteracoes dos dados cadastrais">
      <incoming>f_envia_backend_alt</incoming>
      <outgoing>f_alt_valida</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_04a4zxd" sourceRef="task_registra_log" targetRef="task_retorna_confirmacao" />
    <sequenceFlow id="f_backend_err" sourceRef="gw_salvo_backend" targetRef="task_retorna_erro_salvar" />
    <sequenceFlow id="f_backend_ok" sourceRef="gw_salvo_backend" targetRef="task_registra_log" />
    <sequenceFlow id="f_salva_gw" sourceRef="task_valida_salva" targetRef="gw_salvo_backend" />
    <sequenceFlow id="f_alt_valida" sourceRef="task_recebe_alteracoes" targetRef="task_valida_salva" />
    <sequenceFlow id="f_busca_retorna" sourceRef="task_busca_dados" targetRef="task_retorna_dados" />
    <sequenceFlow id="f_req_busca" sourceRef="task_recebe_req_dados" targetRef="task_busca_dados" />
    <serviceTask id="task_retorna_dados" name="Retorna dados cadastrais para o Frontend">
      <incoming>f_busca_retorna</incoming>
      <outgoing>f_dados_frontend</outgoing>
    </serviceTask>
    <serviceTask id="task_busca_dados" name="Busca dados cadastrais do aluno no banco">
      <incoming>f_req_busca</incoming>
      <outgoing>f_busca_retorna</outgoing>
    </serviceTask>
    <serviceTask id="task_recebe_req_dados" name="Recebe requisicao de dados cadastrais">
      <incoming>f_envia_backend_dados</incoming>
      <outgoing>f_req_busca</outgoing>
    </serviceTask>
    <serviceTask id="task_exibe_erro_validacao" name="Exibe erro de validacao">
      <incoming>Flow_0ctbhy2</incoming>
      <outgoing>Flow_01nfx0r</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_01nfx0r" sourceRef="task_exibe_erro_validacao" targetRef="task_edita_campos" />
  </process>
