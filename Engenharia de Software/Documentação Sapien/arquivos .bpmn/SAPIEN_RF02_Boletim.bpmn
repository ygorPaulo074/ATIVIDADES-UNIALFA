<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://sapien.academic/bpmn" exporter="Camunda Modeler" exporterVersion="5.47.0">
  <collaboration id="Collaboration_boletim">
    <participant id="Participant_boletim" name="PÁGINA DE BOLETIM ESCOLAR - SAPIEN" processRef="proc_boletim" />
  </collaboration>
  <process id="proc_boletim" name="RF02 - Boletim Escolar" isExecutable="false">
    <laneSet id="ls1">
      <lane id="lane_backend" name="Backend / API">
        <flowNodeRef>task_recebe_req_boletim</flowNodeRef>
        <flowNodeRef>task_busca_dados</flowNodeRef>
        <flowNodeRef>task_ret403</flowNodeRef>
        <flowNodeRef>gw_permissao</flowNodeRef>
        <flowNodeRef>gw_tem_dados</flowNodeRef>
        <flowNodeRef>task_ret_sem_dados</flowNodeRef>
        <flowNodeRef>task_retorna_dados</flowNodeRef>
        <flowNodeRef>task_calcula_medias</flowNodeRef>
        <flowNodeRef>task_recebe_req_pdf</flowNodeRef>
        <flowNodeRef>task_gera_pdf</flowNodeRef>
        <flowNodeRef>task_retorna_erro_pdf</flowNodeRef>
        <flowNodeRef>gw_pdf_gerado</flowNodeRef>
        <flowNodeRef>task_retorna_pdf</flowNodeRef>
      </lane>
      <lane id="lane_frontend" name="Frontend">
        <flowNodeRef>task_exibe_erro_403</flowNodeRef>
        <flowNodeRef>task_exibe_sem_dados</flowNodeRef>
        <flowNodeRef>task_renderiza_boletim</flowNodeRef>
        <flowNodeRef>task_envia_req_boletim</flowNodeRef>
        <flowNodeRef>end_sem_dados</flowNodeRef>
        <flowNodeRef>end_sem_permissao</flowNodeRef>
        <flowNodeRef>task_renderiza_tabela</flowNodeRef>
        <flowNodeRef>task_aplica_cores</flowNodeRef>
        <flowNodeRef>gw_frequencia</flowNodeRef>
        <flowNodeRef>end_sucesso</flowNodeRef>
        <flowNodeRef>task_exibe_alerta_freq</flowNodeRef>
        <flowNodeRef>task_download_pdf</flowNodeRef>
        <flowNodeRef>task_envia_req_pdf</flowNodeRef>
        <flowNodeRef>Activity_115onfj</flowNodeRef>
        <flowNodeRef>Gateway_1x27bi3</flowNodeRef>
        <flowNodeRef>end_pdf_erro</flowNodeRef>
        <flowNodeRef>Activity_1i2t20x</flowNodeRef>
        <flowNodeRef>Activity_18swba2</flowNodeRef>
        <flowNodeRef>Event_1k84j1q</flowNodeRef>
      </lane>
      <lane id="lane_usuario" name="Usuario">
        <flowNodeRef>start_boletim</flowNodeRef>
        <flowNodeRef>task_seleciona_periodo</flowNodeRef>
        <flowNodeRef>task_solicita_pdf</flowNodeRef>
      </lane>
    </laneSet>
    <sequenceFlow id="f_fim_boletim" sourceRef="task_exibe_alerta_freq" targetRef="end_sucesso" />
    <serviceTask id="task_busca_dados" name="Busca disciplinas, notas e frequencias do periodo">
      <incoming>f_perm_sim</incoming>
      <outgoing>f_busca_gw</outgoing>
    </serviceTask>
    <serviceTask id="task_exibe_erro_403" name="Exibe mensagem: sem permissao de acesso">
      <incoming>Flow_0i3kpge</incoming>
      <outgoing>f_403_end</outgoing>
    </serviceTask>
    <serviceTask id="task_ret403" name="Retorna 403: sem permissao">
      <incoming>Flow_1kpxf34</incoming>
      <outgoing>Flow_0i3kpge</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_permissao" name="Usuario tem permissao?">
      <incoming>f_req_permissao</incoming>
      <outgoing>f_perm_sim</outgoing>
      <outgoing>Flow_1kpxf34</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="gw_tem_dados" name="Existem dados para o periodo?">
      <incoming>f_busca_gw</incoming>
      <outgoing>f_dados_sim</outgoing>
      <outgoing>Flow_1ajxrdo</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_ret_sem_dados" name="Retorna aviso: nenhum dado encontrado">
      <incoming>Flow_1ajxrdo</incoming>
      <outgoing>f_sem_dados_frontend</outgoing>
    </serviceTask>
    <serviceTask id="task_exibe_sem_dados" name="Exibe aviso: nenhum dado encontrado para o periodo">
      <incoming>f_sem_dados_frontend</incoming>
      <outgoing>Flow_15tfeli</outgoing>
    </serviceTask>
    <serviceTask id="task_retorna_dados" name="Retorna dados do boletim para o Frontend">
      <incoming>f_calcula_retorna</incoming>
      <outgoing>f_dados_frontend</outgoing>
    </serviceTask>
    <serviceTask id="task_calcula_medias" name="Calcula medias automaticamente">
      <incoming>f_dados_sim</incoming>
      <outgoing>f_calcula_retorna</outgoing>
    </serviceTask>
    <serviceTask id="task_recebe_req_pdf" name="Recebe requisicao de PDF">
      <incoming>Flow_0rs7xmi</incoming>
      <outgoing>Flow_08vm4dh</outgoing>
    </serviceTask>
    <startEvent id="start_boletim" name="Acessa a pagina do Boletim">
      <outgoing>f_start_renderiza</outgoing>
    </startEvent>
    <userTask id="task_seleciona_periodo" name="Seleciona o periodo letivo">
      <incoming>f_renderiza_seleciona</incoming>
      <outgoing>f_seleciona_envia</outgoing>
    </userTask>
    <userTask id="task_solicita_pdf" name="Solicita exportacao PDF">
      <outgoing>f_solicita_envia_pdf</outgoing>
    </userTask>
    <serviceTask id="task_renderiza_boletim" name="Renderiza pagina do Boletim">
      <incoming>f_start_renderiza</incoming>
      <outgoing>f_renderiza_seleciona</outgoing>
    </serviceTask>
    <sequenceFlow id="f_envia_backend" sourceRef="task_envia_req_boletim" targetRef="task_recebe_req_boletim" />
    <sequenceFlow id="f_req_permissao" sourceRef="task_recebe_req_boletim" targetRef="gw_permissao" />
    <sequenceFlow id="f_perm_sim" sourceRef="gw_permissao" targetRef="task_busca_dados" />
    <sequenceFlow id="f_busca_gw" sourceRef="task_busca_dados" targetRef="gw_tem_dados" />
    <sequenceFlow id="Flow_0i3kpge" sourceRef="task_ret403" targetRef="task_exibe_erro_403" />
    <sequenceFlow id="f_403_end" sourceRef="task_exibe_erro_403" targetRef="end_sem_permissao" />
    <sequenceFlow id="Flow_1kpxf34" sourceRef="gw_permissao" targetRef="task_ret403" />
    <sequenceFlow id="f_dados_sim" sourceRef="gw_tem_dados" targetRef="task_calcula_medias" />
    <sequenceFlow id="Flow_1ajxrdo" sourceRef="gw_tem_dados" targetRef="task_ret_sem_dados" />
    <sequenceFlow id="f_sem_dados_frontend" sourceRef="task_ret_sem_dados" targetRef="task_exibe_sem_dados" />
    <sequenceFlow id="Flow_15tfeli" sourceRef="task_exibe_sem_dados" targetRef="end_sem_dados" />
    <sequenceFlow id="f_calcula_retorna" sourceRef="task_calcula_medias" targetRef="task_retorna_dados" />
    <sequenceFlow id="f_dados_frontend" sourceRef="task_retorna_dados" targetRef="task_renderiza_tabela" />
    <sequenceFlow id="f_freq_sim" sourceRef="gw_frequencia" targetRef="task_exibe_alerta_freq" />
    <sequenceFlow id="f_solicita_envia_pdf" sourceRef="task_solicita_pdf" targetRef="task_envia_req_pdf" />
    <sequenceFlow id="Flow_0rs7xmi" sourceRef="task_envia_req_pdf" targetRef="task_recebe_req_pdf" />
    <sequenceFlow id="f_seleciona_envia" sourceRef="task_seleciona_periodo" targetRef="task_envia_req_boletim" />
    <sequenceFlow id="f_start_renderiza" sourceRef="start_boletim" targetRef="task_renderiza_boletim" />
    <sequenceFlow id="f_renderiza_seleciona" sourceRef="task_renderiza_boletim" targetRef="task_seleciona_periodo" />
    <serviceTask id="task_envia_req_boletim" name="Envia requisicao com ID do aluno e periodo">
      <incoming>f_seleciona_envia</incoming>
      <outgoing>f_envia_backend</outgoing>
    </serviceTask>
    <serviceTask id="task_recebe_req_boletim" name="Recebe requisicao do boletim">
      <incoming>f_envia_backend</incoming>
      <outgoing>f_req_permissao</outgoing>
    </serviceTask>
    <endEvent id="end_sem_dados" name="Nenhum dado encontrado">
      <incoming>Flow_15tfeli</incoming>
    </endEvent>
    <endEvent id="end_sem_permissao" name="Acesso negado">
      <incoming>f_403_end</incoming>
    </endEvent>
    <serviceTask id="task_renderiza_tabela" name="Renderiza tabela com disciplinas, notas e medias">
      <incoming>f_dados_frontend</incoming>
      <outgoing>Flow_1icu7aq</outgoing>
      <outgoing>Flow_1j1icby</outgoing>
      <outgoing>Flow_03wpgci</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_1icu7aq" sourceRef="task_renderiza_tabela" targetRef="task_download_pdf" />
    <serviceTask id="task_aplica_cores" name="Aplica indicadores visuais por status (Aprovado / Recuperacao / Reprovado)">
      <incoming>Flow_1j1icby</incoming>
      <outgoing>Flow_1ci0ak4</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_1j1icby" sourceRef="task_renderiza_tabela" targetRef="task_aplica_cores" />
    <exclusiveGateway id="gw_frequencia" name="Alguma disciplina abaixo de 75% de frequencia?">
      <incoming>Flow_03wpgci</incoming>
      <outgoing>f_freq_sim</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Flow_03wpgci" sourceRef="task_renderiza_tabela" targetRef="gw_frequencia" />
    <endEvent id="end_sucesso" name="Boletim exibido com sucesso">
      <incoming>f_fim_boletim</incoming>
      <incoming>Flow_0mh3m9l</incoming>
      <incoming>Flow_1ci0ak4</incoming>
      <incoming>Flow_15r16q0</incoming>
    </endEvent>
    <serviceTask id="task_exibe_alerta_freq" name="Exibe alerta de frequencia insuficiente">
      <incoming>f_freq_sim</incoming>
      <outgoing>Flow_0mh3m9l</outgoing>
    </serviceTask>
    <serviceTask id="task_download_pdf" name="Disponibiliza download do PDF">
      <incoming>Flow_1icu7aq</incoming>
      <outgoing>Flow_15r16q0</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_0mh3m9l" sourceRef="task_exibe_alerta_freq" targetRef="end_sucesso" />
    <sequenceFlow id="Flow_1ci0ak4" sourceRef="task_aplica_cores" targetRef="end_sucesso" />
    <sequenceFlow id="Flow_15r16q0" sourceRef="task_download_pdf" targetRef="end_sucesso" />
    <serviceTask id="task_envia_req_pdf" name="Envia requisicao de geracao de PDF">
      <incoming>f_solicita_envia_pdf</incoming>
      <outgoing>Flow_0rs7xmi</outgoing>
    </serviceTask>
    <serviceTask id="task_gera_pdf" name="Gera arquivo PDF do boletim">
      <incoming>Flow_08vm4dh</incoming>
      <outgoing>Flow_02j01gv</outgoing>
    </serviceTask>
    <serviceTask id="task_retorna_erro_pdf" name="Retorna erro na geracao do PDF">
      <incoming>Flow_10vp8y0</incoming>
      <outgoing>f_pdf_frontend</outgoing>
      <outgoing>Flow_05j7ykh</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_pdf_gerado" name="PDF gerado com sucesso?">
      <incoming>Flow_02j01gv</incoming>
      <outgoing>Flow_10vp8y0</outgoing>
      <outgoing>Flow_1mpv0y9</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Flow_08vm4dh" sourceRef="task_recebe_req_pdf" targetRef="task_gera_pdf" />
    <sequenceFlow id="Flow_02j01gv" sourceRef="task_gera_pdf" targetRef="gw_pdf_gerado" />
    <sequenceFlow id="Flow_10vp8y0" sourceRef="gw_pdf_gerado" targetRef="task_retorna_erro_pdf" />
    <sequenceFlow id="Flow_1mpv0y9" sourceRef="gw_pdf_gerado" targetRef="task_retorna_pdf" />
    <serviceTask id="task_retorna_pdf" name="Retorna PDF para o Frontend">
      <incoming>Flow_1mpv0y9</incoming>
      <outgoing>Flow_04i5i6q</outgoing>
    </serviceTask>
    <serviceTask id="Activity_115onfj" name="Recebe resposta de geracao de PDF">
      <incoming>Flow_05j7ykh</incoming>
      <incoming>Flow_04i5i6q</incoming>
      <outgoing>Flow_1v8mas8</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_05j7ykh" sourceRef="task_retorna_erro_pdf" targetRef="Activity_115onfj" />
    <sequenceFlow id="Flow_04i5i6q" sourceRef="task_retorna_pdf" targetRef="Activity_115onfj" />
    <exclusiveGateway id="Gateway_1x27bi3" name="PDF gerado com sucesso?">
      <incoming>Flow_1v8mas8</incoming>
      <outgoing>Flow_138m5ps</outgoing>
      <outgoing>Flow_0i6mp45</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Flow_1v8mas8" sourceRef="Activity_115onfj" targetRef="Gateway_1x27bi3" />
    <endEvent id="end_pdf_erro" name="Erro na geracao do PDF">
      <incoming>Flow_0fywzpj</incoming>
    </endEvent>
    <sequenceFlow id="Flow_138m5ps" sourceRef="Gateway_1x27bi3" targetRef="Activity_1i2t20x" />
    <serviceTask id="Activity_1i2t20x" name="Exibe alerta de erro na geração do PDF">
      <incoming>Flow_138m5ps</incoming>
      <outgoing>Flow_0fywzpj</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_0i6mp45" sourceRef="Gateway_1x27bi3" targetRef="Activity_18swba2" />
    <sequenceFlow id="Flow_0fywzpj" sourceRef="Activity_1i2t20x" targetRef="end_pdf_erro" />
    <sequenceFlow id="Flow_1gu5fbz" sourceRef="Activity_18swba2" targetRef="Event_1k84j1q" />
    <serviceTask id="Activity_18swba2" name="Exibe PDF ao usuário">
      <incoming>Flow_0i6mp45</incoming>
      <outgoing>Flow_1gu5fbz</outgoing>
    </serviceTask>
    <endEvent id="Event_1k84j1q" name="Baixa PDF na máquina do usuário">
      <incoming>Flow_1gu5fbz</incoming>
    </endEvent>
  </process>
