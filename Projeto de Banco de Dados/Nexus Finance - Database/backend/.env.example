# Variáveis de ambiente do backend (FastAPI + Groq)
# Copie para .env e preencha com suas chaves reais:  cp .env.example .env

# Chave da API Groq (LLM Llama 3.3) — https://console.groq.com
GROQ_API_KEY=

# Chave da API Tavily (busca na web) — https://tavily.com
TAVILY_API_KEY=

# Origem permitida para CORS (URL do frontend)
CORS_ORIGIN=http://localhost:5173

# Nome do assistente
BOT_NAME=Jarvis

# Token da brapi.dev (cotações de investimentos) — https://brapi.dev/dashboard
BRAPI_TOKEN=

# Redis (camada de IA efêmera, TTL 24h). No Docker: redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

# PostgreSQL (domínio financeiro). No Docker: db:5432
DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres
